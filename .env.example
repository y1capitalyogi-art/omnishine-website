# ===== Build-time (public) =====
# Cloudflare Turnstile sitekey — loaded in browser
PUBLIC_TURNSTILE_SITEKEY=0x0000000000000000000000000000000000000000

# Cloudflare Web Analytics token — omit locally; set in Cloudflare Pages prod env
PUBLIC_CF_ANALYTICS_TOKEN=

# ===== Function runtime (secret) =====
# Set these via Cloudflare Pages dashboard → Settings → Environment variables (Production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000
FROM_EMAIL="Omni Shine <info@omnishine.co.uk>"

# ===== Local testing (Turnstile sandbox keys — always pass) =====
# PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
