---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import FaqList from '../../components/FaqList.astro';
import AreaCard from '../../components/AreaCard.astro';
import { site } from '../../content/site';
import { serviceSchema, breadcrumbSchema, faqSchema } from '../../lib/schema';

const s = site.services.find(x => x.slug === 'deep-cleaning-oldham')!;
const path = `/services/${s.slug}/`;
const url = `${site.url}${path}`;

const included = [
  'Kitchen degrease — hob, extractor, cabinets inside and out',
  'Oven and microwave deep clean',
  'Bathroom limescale, grout and tile detail',
  'Skirtings, door frames, light switches, radiators',
  'Inside windows, sills and frames',
  'Carpet vacuum with upholstery attachment',
  'Full dust-down from high shelves to baseboards',
  'Removal of cobwebs, mould spots and built-up grime',
];

const localFaqs = [
  { q: 'How long does a deep clean take?', a: 'A one-bed flat takes 4–6 hours with two cleaners. A three-bed house takes a full day. We will confirm a time estimate with your fixed quote.' },
  { q: 'Do you move furniture?', a: 'We move light furniture (chairs, small tables, rugs). We do not move beds, wardrobes, or heavy appliances — but we clean behind what we can safely shift.' },
  { q: 'Can you do just kitchen or just bathroom?', a: 'Yes. A kitchen-only deep clean is from £90; bathroom-only from £70. Add both and we bundle at £140.' },
  { q: 'Do you clean carpets with a steam machine?', a: 'Not as standard. We vacuum thoroughly and spot-treat marks. Full carpet extraction is an add-on — we can arrange and quote it.' },
  { q: 'When is a deep clean worth it over a standard one?', a: 'When you move in, move out, have just renovated, come back from holiday, or it has been 6+ months since the last proper going-over.' },
];

const schemas = [
  serviceSchema(s),
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Services', url: `${site.url}/#services` },
    { name: s.name, url },
  ]),
  faqSchema(localFaqs),
];
---
<Page
  title="Deep Cleaning in Oldham | One-Off, Top-to-Bottom | From £150"
  description="Top-to-bottom deep cleans in Oldham from £150. Kitchens, bathrooms, ovens, windows and carpets — ideal for spring cleans, pre-sale prep, or fresh starts."
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Services',href:'/#services'},{name:s.name}]} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <header>
      <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">From £{s.from} fixed</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900 tracking-tight">Deep Cleaning in Oldham</h1>
      <p class="mt-5 text-lg text-slate-700 leading-relaxed">
        One-off, top-to-bottom cleans that get into the corners most weekly services skip — <strong>from £{s.from}</strong>, fixed quote. Ideal for spring cleans, pre-sale staging, post-illness resets, or when it's just been a while.
      </p>
    </header>

    <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 md:p-8">
      <h2 class="font-display text-xl text-navy-900">What a deep clean covers</h2>
      <ul class="mt-4 grid gap-3 text-slate-700 md:grid-cols-2">
        {included.map(i => (
          <li class="flex items-start gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{i}</span>
          </li>
        ))}
      </ul>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Fixed prices by property size</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-600"><tr><th class="p-3">Property</th><th class="p-3">From</th><th class="p-3">Time</th></tr></thead>
        <tbody class="text-slate-800">
          <tr class="border-t border-slate-200"><td class="p-3">Studio / 1-bed flat</td><td class="p-3">£150</td><td class="p-3">4–6 hrs</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">2-bed house or flat</td><td class="p-3">£220</td><td class="p-3">6–8 hrs</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">3-bed house</td><td class="p-3">£290</td><td class="p-3">8–10 hrs</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">4+ bed</td><td class="p-3">On quote</td><td class="p-3">Full day+</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-slate-500">Prices assume a normally-lived-in condition. Exceptional dirt, mould or hoarded waste attracts a supplement, agreed before work starts.</p>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Where we deep-clean</h2>
    <p class="mt-4 text-slate-700">Across all {site.areas.length} towns we serve around Oldham.</p>
    <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {site.areaPages.map(a => <AreaCard href={`/areas/${a.toLowerCase()}/`} name={a} />)}
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Common questions</h2>
    <div class="mt-4"><FaqList items={localFaqs} /></div>

    <div id="quote" class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Get your fixed deep-clean quote</h2>
      <p class="mt-2 text-slate-600">Tell us bedroom count and any problem areas — we'll price it properly.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </article>
</Page>
