---
import { Image } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import FaqList from '../../components/FaqList.astro';
import { site } from '../../content/site';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import office from '../../assets/photos/office.jpg';

const path = '/services/commercial-cleaning-ashton-under-lyne/';
const url = `${site.url}${path}`;

const included = [
  'Desks, surfaces and meeting rooms wiped down',
  'Kitchens and washrooms restocked and sanitised',
  'Bins emptied, liners replaced, recycling separated',
  'Carpets vacuumed, hard floors mopped',
  'Glass partitions and shopfront glass spot-cleaned',
  'Daily, weekly or fortnightly schedules — your call',
];

const localFaqs = [
  { q: 'Do you cover Ashton town centre and the market hall area?',
    a: 'Yes — independent shops on Stamford Street, salons around Old Square, and offices near the bus interchange are regular clients. We work outside opening hours so we never get in your customers\' way.' },
  { q: 'Can you handle salons and beauty studios?',
    a: 'Yes. Hair salons, nail bars, barber shops and beauty studios across Ashton get our standard commercial spec plus the salon-specific extras (chair-side wipe-downs, mirror polish, drain hair removal). Quote separately if needed.' },
  { q: 'Can you invoice us monthly?',
    a: 'Yes. Monthly invoicing on 7-day terms is standard for commercial work in Ashton. Bank transfer or Stripe — your call.' },
  { q: 'Can you do multi-site contracts in Tameside?',
    a: 'Yes — we cover Ashton, Mossley, Stalybridge and Hyde under the same contract. Bundled pricing is usually possible for 3+ sites.' },
  { q: 'Do you have references in Ashton?',
    a: 'We are a newly founded business (2026) but have growing commercial clients across Tameside. Ask on the form and we will put you in touch with the closest reference site.' },
];

const customService = { from: 22 };

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${url}#service`,
    name: 'Commercial Cleaning in Ashton-under-Lyne',
    description: 'Office, retail, salon and shared-workspace cleaning across Ashton-under-Lyne and wider Tameside from £22/hr.',
    provider: { '@id': `${site.url}/#business` },
    areaServed: ['Ashton-under-Lyne', 'Hurst', 'Smallshaw', 'Hartshead', 'Mossley', 'Stalybridge'].map(a => ({ '@type': 'Place', name: a })),
    serviceType: 'Commercial Cleaning',
    offers: {
      '@type': 'Offer',
      priceCurrency: 'GBP',
      price: customService.from,
      availability: 'https://schema.org/InStock',
      priceSpecification: {
        '@type': 'PriceSpecification',
        price: customService.from,
        priceCurrency: 'GBP',
        description: '/ hour',
      },
    },
  },
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Services', url: `${site.url}/#services` },
    { name: 'Commercial Cleaning in Ashton-under-Lyne', url },
  ]),
  faqSchema(localFaqs),
];
---
<Page
  title="Commercial Cleaning in Ashton-under-Lyne | From £22/hr | Omni Shine"
  description="Office, retail and salon cleaning across Ashton-under-Lyne, Hurst, Smallshaw and wider Tameside. From £22/hr, evenings and weekends, monthly invoicing."
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Services',href:'/#services'},{name:'Commercial Cleaning in Ashton-under-Lyne'}]} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <header>
      <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">From £{customService.from}/hr · Evenings &amp; weekends</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900 tracking-tight">Commercial Cleaning in Ashton-under-Lyne</h1>
      <p class="mt-5 text-lg text-slate-700 leading-relaxed">
        Discreet, reliable cleaning for offices, retail units, salons and shared workspaces across <strong>Ashton-under-Lyne, Hurst, Smallshaw, Hartshead</strong> and wider Tameside — from <strong>£{customService.from}/hr</strong>. Evenings and weekends as standard, monthly invoicing on 7-day terms.
      </p>
      <Image
        src={office}
        alt="Clean modern office in Ashton-under-Lyne ready for the morning"
        widths={[600, 900, 1200, 1600]}
        sizes="(min-width: 768px) 768px, 100vw"
        quality={78}
        format="webp"
        loading="eager"
        fetchpriority="high"
        class="mt-8 rounded-2xl shadow-xl ring-1 ring-slate-200 w-full h-auto object-cover aspect-[16/9]"
      />
    </header>

    <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 md:p-8">
      <h2 class="font-display text-xl text-navy-900">What a standard Ashton commercial visit covers</h2>
      <ul class="mt-4 grid gap-3 text-slate-700 md:grid-cols-2">
        {included.map(i => (
          <li class="flex items-start gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{i}</span>
          </li>
        ))}
      </ul>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Who we work with in Ashton</h2>
    <ul class="mt-4 space-y-3 text-slate-700">
      <li><strong>Independent retail</strong> — Stamford Street shops, market hall units, high-street stores.</li>
      <li><strong>Salons and barbers</strong> — hair, nails, beauty, including post-treatment sanitising.</li>
      <li><strong>Offices and serviced workspace</strong> — small and mid-sized teams up to 30 desks.</li>
      <li><strong>Cafés and bars</strong> — pre-opening cleans, deep cleans on Sundays, kitchen schedules.</li>
      <li><strong>Multi-site Tameside contracts</strong> — Ashton + Mossley + Stalybridge bundled.</li>
    </ul>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Scheduling</h2>
    <ul class="mt-4 space-y-3 text-slate-700">
      <li><strong>Daily:</strong> Mon–Fri evenings (after 5pm) for customer-facing spaces.</li>
      <li><strong>Weekly or fortnightly:</strong> Any day, any time after 5pm or before 9am.</li>
      <li><strong>One-off deep cleans:</strong> For lease handovers, rebrands, or after events.</li>
    </ul>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Common questions</h2>
    <div class="mt-4"><FaqList items={localFaqs} /></div>

    <div class="mt-12 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
      <h3 class="font-semibold text-navy-900">Other Ashton-relevant pages</h3>
      <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
        <li>✦ <a href="/areas/ashton-under-lyne/" class="font-semibold underline hover:text-navy-900">Ashton-under-Lyne area page</a></li>
        <li>✦ <a href="/areas/mossley/" class="font-semibold underline hover:text-navy-900">Mossley area page</a></li>
        <li>✦ <a href="/services/commercial-cleaning-oldham/" class="font-semibold underline hover:text-navy-900">Commercial cleaning — wider Oldham</a></li>
      </ul>
    </div>

    <div id="quote" class="mt-12 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Get your Ashton commercial cleaning quote</h2>
      <p class="mt-2 text-slate-600">Site walk-throughs available — usually replied within two working hours.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </article>
</Page>
