---
import { Image } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import FaqList from '../../components/FaqList.astro';
import { site } from '../../content/site';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import livingRoom from '../../assets/photos/living-room.jpg';

const path = '/services/end-of-tenancy-cleaning-rochdale/';
const url = `${site.url}${path}`;

const included = [
  'Every room cleaned to letting-agent inventory standard',
  'Full oven, hob, extractor and microwave deep clean',
  'Inside and outside of all cupboards, drawers and wardrobes',
  'Bathrooms descaled — tiles, grout, fixtures, screens',
  'Skirtings, door frames, window sills, light switches',
  'Fridge and freezer defrosted and wiped (if switched off)',
  'Carpets vacuumed; hard floors mopped',
  'Final walk-through, photo-confirmation when complete',
];

const localFaqs = [
  { q: 'Do you work with Rochdale letting agents?',
    a: 'Yes. We complete cleans to the standard inventory checklist most Rochdale letting agents and inventory clerks use. We are happy to liaise directly with the agent on check-out if you give us their contact.' },
  { q: 'Can you handle student and HMO turnovers?',
    a: 'Yes — multi-bedroom HMOs and student houses are bread-and-butter work. We bring extra hands for larger properties and quote a fixed price after a quick photo walk-through.' },
  { q: 'How much notice do you need?',
    a: 'Same-week starts are usually possible. We can occasionally do same-day at the weekend. Tighter turnarounds always come with a clean priority — if you tell us your check-out time we will work around it.' },
  { q: 'Will you clean carpets?',
    a: 'We vacuum thoroughly and spot-treat marks as standard. Professional carpet extraction is an add-on — most Rochdale letting agents accept thorough vacuuming for shorter tenancies, but if your tenancy agreement requires extraction we will arrange it on quote.' },
  { q: 'Do you cover all of Rochdale borough?',
    a: 'Yes — town centre, Castleton, Norden, Spotland, Milnrow, Heywood and Littleborough. Outside that we will quote travel separately.' },
];

const customService = {
  from: 180,
};

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${url}#service`,
    name: 'End of Tenancy Cleaning in Rochdale',
    description: 'Deposit-back end-of-tenancy cleans across Rochdale and surrounding boroughs from £180 fixed.',
    provider: { '@id': `${site.url}/#business` },
    areaServed: ['Rochdale', 'Castleton', 'Norden', 'Spotland', 'Milnrow', 'Heywood', 'Littleborough'].map(a => ({ '@type': 'Place', name: a })),
    serviceType: 'End of Tenancy Cleaning',
    offers: {
      '@type': 'Offer',
      priceCurrency: 'GBP',
      price: customService.from,
      availability: 'https://schema.org/InStock',
      priceSpecification: {
        '@type': 'PriceSpecification',
        price: customService.from,
        priceCurrency: 'GBP',
        description: 'from',
      },
    },
  },
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Services', url: `${site.url}/#services` },
    { name: 'End of Tenancy in Rochdale', url },
  ]),
  faqSchema(localFaqs),
];
---
<Page
  title="End of Tenancy Cleaning in Rochdale | From £180 | Omni Shine"
  description="Deposit-back end-of-tenancy cleans in Rochdale, Castleton, Norden, Spotland, Milnrow and Heywood. From £180, 72-hour re-clean guarantee, weekend slots."
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Services',href:'/#services'},{name:'End of Tenancy in Rochdale'}]} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header>
      <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">From £{customService.from} fixed · 72-hour re-clean</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900 tracking-tight">End of Tenancy Cleaning in Rochdale</h1>
      <p class="mt-5 text-lg text-slate-700 leading-relaxed">
        Inventory-standard end-of-tenancy cleans across <strong>Rochdale, Castleton, Norden, Spotland, Milnrow, Heywood</strong> and <strong>Littleborough</strong>. Fixed quotes from <strong>£{customService.from}</strong>, with a 72-hour re-clean guarantee if your letting agent flags any cleaning issues.
      </p>
      <Image
        src={livingRoom}
        alt="Rental property living room post-tenancy clean — ready for the inventory clerk"
        widths={[600, 900, 1200, 1600]}
        sizes="(min-width: 768px) 768px, 100vw"
        quality={78}
        format="webp"
        loading="eager"
        fetchpriority="high"
        class="mt-8 rounded-2xl shadow-xl ring-1 ring-slate-200 w-full h-auto object-cover aspect-[16/9]"
      />
    </header>

    <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 md:p-8">
      <h2 class="font-display text-xl text-navy-900">The full Rochdale end-of-tenancy spec</h2>
      <ul class="mt-4 grid gap-3 text-slate-700 md:grid-cols-2">
        {included.map(i => (
          <li class="flex items-start gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{i}</span>
          </li>
        ))}
      </ul>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Built for the Rochdale rental market</h2>
    <p class="mt-4 text-slate-700">Rochdale has a substantial rental market: town-centre flats, terraced HMOs, family lets in Castleton and Norden, student housing close to Hopwood Hall. We're set up for the volume — same-day starts, multi-cleaner teams for bigger properties, and tight communication with letting agents and inventory clerks.</p>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Pricing for Rochdale properties</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-600"><tr><th class="p-3">Property</th><th class="p-3">From</th></tr></thead>
        <tbody class="text-slate-800">
          <tr class="border-t border-slate-200"><td class="p-3">Studio / 1-bed flat</td><td class="p-3">£180</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">2-bed flat / terraced house</td><td class="p-3">£240</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">3-bed house / HMO</td><td class="p-3">£320</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">4+ bed HMO / family house</td><td class="p-3">On quote</td></tr>
        </tbody>
      </table>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">72-hour re-clean — what it actually means</h2>
    <p class="mt-4 text-slate-700">If your letting agent reports any cleaning issue during check-out within 72 hours of our visit, we return and re-clean those areas free of charge. No quibbles, no admin loops. We'd rather come back and fix it than have you fight a deposit dispute over a missed corner.</p>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Common questions</h2>
    <div class="mt-4"><FaqList items={localFaqs} /></div>

    <div id="quote" class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Book your Rochdale end-of-tenancy clean</h2>
      <p class="mt-2 text-slate-600">Tell us check-out date, bedrooms and postcode — we'll fix the price today.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </article>
</Page>
