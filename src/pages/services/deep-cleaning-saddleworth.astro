---
import { Image } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import FaqList from '../../components/FaqList.astro';
import { site } from '../../content/site';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const path = '/services/deep-cleaning-saddleworth/';
const url = `${site.url}${path}`;

const included = [
  'pH-neutral cleaners on flagstones, Yorkshire stone and exposed beams',
  'Kitchen degrease — hob, extractor, cabinets inside and out',
  'Oven and microwave deep clean',
  'Bathroom limescale, grout and tile detail',
  'Inside windows, sills, frames and original sashes',
  'Cobwebs from beams, period mouldings and high corners',
  'Skirtings, door frames, light switches, radiators',
  'Carpets vacuumed; flagstone floors washed and re-sealed if needed',
];

const localFaqs = [
  { q: 'Are you used to cleaning stone-cottage interiors?',
    a: 'Yes — most of our Saddleworth deep cleans are in old stone cottages with flagstone floors, sandblasted stone walls and original Yorkshire-stone fireplaces. We use pH-neutral cleaners and never abrasive scrubs. Test in an inconspicuous spot first is our default.' },
  { q: 'Will you clean exposed beams without damaging them?',
    a: 'Yes. Beams get a soft microfibre dust-down and only a damp cloth where genuinely needed. We do not use solvents or polishes that could darken old timber unless you specifically ask.' },
  { q: 'How long does a Saddleworth deep clean take?',
    a: 'A 2-bed cottage typically takes 6–8 hours with two cleaners. A 3-bed barn conversion takes a full day. We can also split the job across two visits if scheduling is tight.' },
  { q: 'Do you do pre-sale deep cleans?',
    a: 'Often. Most of our pre-sale work is for Saddleworth properties going to market — the brief is to make the cottage photograph beautifully. We work to a tight checklist that prioritises what estate-agent photos actually pick up.' },
  { q: 'Can you do post-renovation deep cleans on stone properties?',
    a: 'Yes. After-builders deep cleans on period properties are different to modern builds — we know the difference between dust on slate and dust on porcelain. See our <a href="/services/after-builders-cleaning-oldham/">after-builders page</a> too.' },
];

const customService = { from: 150 };

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${url}#service`,
    name: 'Deep Cleaning in Saddleworth',
    description: 'Top-to-bottom deep cleans across the Saddleworth villages — from £150, careful with period stone properties.',
    provider: { '@id': `${site.url}/#business` },
    areaServed: ['Uppermill', 'Greenfield', 'Delph', 'Dobcross', 'Diggle', 'Saddleworth', 'Grotton', 'Springhead', 'Mossley'].map(a => ({ '@type': 'Place', name: a })),
    serviceType: 'Deep Cleaning',
    offers: {
      '@type': 'Offer',
      priceCurrency: 'GBP',
      price: customService.from,
      availability: 'https://schema.org/InStock',
      priceSpecification: {
        '@type': 'PriceSpecification',
        price: customService.from,
        priceCurrency: 'GBP',
        description: 'from',
      },
    },
  },
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Services', url: `${site.url}/#services` },
    { name: 'Deep Cleaning in Saddleworth', url },
  ]),
  faqSchema(localFaqs),
];
---
<Page
  title="Deep Cleaning in Saddleworth | Stone-Cottage Friendly | From £150 | Omni Shine"
  description="Top-to-bottom deep cleans across the Saddleworth villages — Uppermill, Greenfield, Delph, Dobcross, Diggle. Stone-cottage safe, pre-sale ready, from £150 fixed."
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Services',href:'/#services'},{name:'Deep Cleaning in Saddleworth'}]} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <header>
      <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">From £{customService.from} fixed · Stone-cottage friendly</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900 tracking-tight">Deep Cleaning in Saddleworth</h1>
      <p class="mt-5 text-lg text-slate-700 leading-relaxed">
        Top-to-bottom one-off deep cleans across the Saddleworth villages — <strong>Uppermill, Greenfield, Delph, Dobcross, Diggle, Grotton</strong> and <strong>Springhead</strong>. Designed for period stone cottages, barn conversions, and the kind of property a generic clean would damage.
      </p>
      <Image
        src={stoneCottage}
        alt="Saddleworth-style English stone cottage in the Pennine landscape"
        widths={[600, 900, 1200, 1600]}
        sizes="(min-width: 768px) 768px, 100vw"
        quality={78}
        format="webp"
        loading="eager"
        fetchpriority="high"
        class="mt-8 rounded-2xl shadow-xl ring-1 ring-slate-200 w-full h-auto object-cover aspect-[16/9]"
      />
    </header>

    <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 md:p-8">
      <h2 class="font-display text-xl text-navy-900">What a Saddleworth deep clean covers</h2>
      <ul class="mt-4 grid gap-3 text-slate-700 md:grid-cols-2">
        {included.map(i => (
          <li class="flex items-start gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{i}</span>
          </li>
        ))}
      </ul>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Period properties get a careful approach</h2>
    <p class="mt-4 text-slate-700">Saddleworth has more period stone homes per square mile than almost anywhere in Greater Manchester. Flagstone hallways, sandblasted stone walls, original sashes, exposed beams, sandstone fireplaces — the wrong product on any of these can do permanent damage. We use pH-neutral cleaners as standard, soft microfibre on stone, and always test on a hidden patch before applying anything new.</p>

    <h2 class="mt-14 font-display text-2xl text-navy-900">When to book a Saddleworth deep clean</h2>
    <ul class="mt-4 space-y-3 text-slate-700">
      <li><strong>Pre-sale or pre-let staging</strong> — make the property photograph and viewing-ready.</li>
      <li><strong>Spring or autumn refresh</strong> — open chimneys, dust-laden beams, the works.</li>
      <li><strong>Holiday-let between long-stay guests</strong> — when standard turnovers aren't enough.</li>
      <li><strong>Post-renovation</strong> — paired with our <a href="/services/after-builders-cleaning-oldham/" class="underline hover:text-navy-900">after-builders service</a>.</li>
      <li><strong>Pre-arrival of family / guests staying long-term</strong> — full reset of the property.</li>
    </ul>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Saddleworth deep-clean pricing</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-600"><tr><th class="p-3">Property</th><th class="p-3">From</th><th class="p-3">Time</th></tr></thead>
        <tbody class="text-slate-800">
          <tr class="border-t border-slate-200"><td class="p-3">Studio / 1-bed cottage</td><td class="p-3">£150</td><td class="p-3">4–6 hrs</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">2-bed cottage / apartment</td><td class="p-3">£220</td><td class="p-3">6–8 hrs</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">3-bed house / barn conversion</td><td class="p-3">£290</td><td class="p-3">Full day</td></tr>
          <tr class="border-t border-slate-200"><td class="p-3">4+ bed</td><td class="p-3">On quote</td><td class="p-3">1–2 days</td></tr>
        </tbody>
      </table>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Specific Saddleworth villages we cover</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      <li>✦ <a href="/areas/uppermill/" class="underline hover:text-navy-900">Cleaners in Uppermill</a></li>
      <li>✦ <a href="/areas/greenfield/" class="underline hover:text-navy-900">Cleaners in Greenfield</a></li>
      <li>✦ <a href="/areas/delph/" class="underline hover:text-navy-900">Cleaners in Delph</a></li>
      <li>✦ <a href="/areas/grotton/" class="underline hover:text-navy-900">Cleaners in Grotton</a></li>
      <li>✦ <a href="/areas/springhead/" class="underline hover:text-navy-900">Cleaners in Springhead</a></li>
      <li>✦ <a href="/areas/mossley/" class="underline hover:text-navy-900">Cleaners in Mossley</a></li>
    </ul>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Common questions</h2>
    <div class="mt-4"><FaqList items={localFaqs} /></div>

    <div class="mt-12 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
      <h3 class="font-semibold text-navy-900">Other Saddleworth services</h3>
      <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
        <li>✦ <a href="/services/end-of-tenancy-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">End of tenancy cleaning in Saddleworth</a></li>
        <li>✦ <a href="/areas/saddleworth/" class="font-semibold underline hover:text-navy-900">Saddleworth area page</a> — for weekly and fortnightly domestic</li>
      </ul>
    </div>

    <div id="quote" class="mt-12 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Get your Saddleworth deep-clean quote</h2>
      <p class="mt-2 text-slate-600">Bedrooms + property type + any problem areas — we'll fix the price today.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </article>
</Page>
