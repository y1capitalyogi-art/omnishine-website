---
import { Image } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import FaqList from '../../components/FaqList.astro';
import AreaCard from '../../components/AreaCard.astro';
import { site } from '../../content/site';
import { serviceSchema, breadcrumbSchema, faqSchema } from '../../lib/schema';
import afterBuilders from '../../assets/photos/after-builders.jpg';

const s = site.services.find(x => x.slug === 'after-builders-cleaning-oldham')!;
const path = `/services/${s.slug}/`;
const url = `${site.url}${path}`;

const included = [
  'Fine construction dust removed from every surface',
  'Paint spots, silicone and sealant residue removed',
  'Floors swept, hoovered and wet-mopped (incl. under edges)',
  'Windows, frames and sills cleaned inside',
  'Kitchen cabinets (inside and out) and worktops polished',
  'Bathrooms scrubbed, grouted and sanitised',
  'Fixtures, light-switches, sockets and radiators wiped',
  'Protective sheeting / floor covering removed and disposed',
  'Skirting boards and door frames detailed',
];

const localFaqs = [
  { q: 'Will you dispose of leftover debris or rubble?', a: 'Small amounts (bagged off-cuts, packaging) yes — we bag and leave them for the builder or your waste collection. Skips and heavy debris should be handled by your builder.' },
  { q: 'How soon can you start after a build?', a: 'We prefer 24 hours after the builders finish so dust has a chance to settle. We can start sooner on urgent jobs.' },
  { q: 'Do you handle multiple visits for phased builds?', a: 'Yes — for extensions and full refurbs we often do a first rough clean then a finishing clean once all trades are out. Quote covers both.' },
  { q: 'What do you not clean after a build?', a: 'We don\'t do paint touch-ups, grout re-pointing, silicone application, or sanding. If a surface is damaged we flag it rather than try to repair it.' },
  { q: 'Do you bring a vacuum rated for construction dust?', a: 'Yes. We use HEPA-grade vacuums for after-builders work — standard vacuums blow fine dust back into the air.' },
];

const schemas = [
  serviceSchema(s),
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Services', url: `${site.url}/#services` },
    { name: s.name, url },
  ]),
  faqSchema(localFaqs),
];
---
<Page
  title="After Builders Cleaning in Oldham | From £200 | Omni Shine"
  description="Post-renovation cleans in Oldham from £200. HEPA-grade dust removal, paint residue, full finish — we hand your space back move-in ready."
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Services',href:'/#services'},{name:s.name}]} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header>
      <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">From £{s.from} fixed · HEPA-grade</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900 tracking-tight">After-Builders Cleaning in Oldham</h1>
      <p class="mt-5 text-lg text-slate-700 leading-relaxed">
        Builders leave beautiful work and a dust storm. We remove every speck — <strong>from £{s.from}</strong>, fixed, with HEPA-grade vacuums so the fine dust ends up in the bin, not back in the air you breathe.
      </p>
      <Image
        src={afterBuilders}
        alt="Newly renovated room ready for the after-builders deep clean"
        widths={[600, 900, 1200, 1600]}
        sizes="(min-width: 768px) 768px, 100vw"
        quality={78}
        format="webp"
        loading="eager"
        fetchpriority="high"
        class="mt-8 rounded-2xl shadow-xl ring-1 ring-slate-200 w-full h-auto object-cover aspect-[16/9]"
      />
    </header>

    <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6 md:p-8">
      <h2 class="font-display text-xl text-navy-900">Full post-renovation checklist</h2>
      <ul class="mt-4 grid gap-3 text-slate-700 md:grid-cols-2">
        {included.map(i => (
          <li class="flex items-start gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{i}</span>
          </li>
        ))}
      </ul>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">When to book us in</h2>
    <ul class="mt-4 space-y-3 text-slate-700">
      <li><strong>Single-room refits</strong> (new kitchen or bathroom) — book a half-day clean right after snagging.</li>
      <li><strong>Extensions and full refurbs</strong> — often a two-visit plan: rough clean after trades finish, finishing clean before you move in.</li>
      <li><strong>Commercial fit-outs</strong> — new shop, café or studio. We can scheduled around your opening day.</li>
    </ul>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Areas we cover</h2>
    <p class="mt-4 text-slate-700">All {site.areas.length} towns around Oldham.</p>
    <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {site.areaPages.map(a => <AreaCard href={`/areas/${a.toLowerCase()}/`} name={a} />)}
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Common questions</h2>
    <div class="mt-4"><FaqList items={localFaqs} /></div>

    <div id="quote" class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Get an after-builders quote</h2>
      <p class="mt-2 text-slate-600">Photos of the site speed up the quote — attach or describe when you message us.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </article>
</Page>
