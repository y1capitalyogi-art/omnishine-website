---
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../content/site';
import { breadcrumbSchema } from '../lib/schema';

const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Cookies', url: `${site.url}/cookies/` },
])];
---
<Page
  title="Cookies Policy | Omni Shine Cleaning"
  description="Omni Shine Cleaning does not use tracking cookies. Here's the detail on the one strictly-necessary cookie our spam protection may set."
  path="/cookies/"
  schemas={schemas}
>
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white">
    <div class="absolute inset-0 opacity-30 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-navy-500 blur-3xl mix-blend-screen"></div>
      <div class="absolute top-1/3 -right-32 w-[28rem] h-[28rem] rounded-full bg-gold-400/40 blur-3xl mix-blend-screen"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 md:pb-20">
      <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Cookies'}]} />
      <div class="mt-6 max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30">Legal</p>
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight">Cookies policy</h1>
        <p class="mt-5 text-lg text-slate-100/95">No tracking cookies. No advertising pixels. That's why we don't show you a banner.</p>
      </div>
    </div>
  </section>

  <article class="mx-auto max-w-3xl px-4 py-14 md:py-20 space-y-6 text-slate-700 leading-relaxed">
    <div class="rounded-2xl bg-emerald-50 border border-emerald-200 p-5 text-emerald-900">
      <p class="font-semibold">Short version</p>
      <p class="mt-1 text-sm">We don't use tracking cookies. No advertising pixels, no marketing cookies, no cross-site tracking — that's why this site doesn't have a cookie banner.</p>
    </div>

    <h2 class="font-display text-2xl text-navy-900 pt-4">Analytics</h2>
    <p>We use <strong>Cloudflare Web Analytics</strong>, which is cookieless and does not track individual visitors or set any cookies on your device.</p>

    <h2 class="font-display text-2xl text-navy-900 pt-4">Spam protection</h2>
    <p>Our contact form uses <strong>Cloudflare Turnstile</strong>. Turnstile may set a short-lived, strictly-necessary cookie when you submit the form, solely to verify you are not a bot. Under the UK Privacy and Electronic Communications Regulations (PECR), cookies strictly necessary for a service you have requested are exempt from consent. This cookie is not used for tracking and is deleted when you close your browser.</p>

    <h2 class="font-display text-2xl text-navy-900 pt-4">Third-party embeds</h2>
    <p>We do not embed YouTube videos, Facebook widgets, Twitter timelines, or other third-party elements that would set their own cookies.</p>

    <h2 class="font-display text-2xl text-navy-900 pt-4">If you still want to block everything</h2>
    <p>You can disable all cookies in your browser — this site will continue to work normally, including the contact form.</p>

    <p class="text-sm text-slate-500 pt-6">Questions? Email <a href={`mailto:${site.email}`} class="underline">{site.email}</a>.</p>
  </article>
</Page>
