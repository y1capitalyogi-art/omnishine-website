---
import { Image } from 'astro:assets';
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { breadcrumbSchema, faqSchema } from '../lib/schema';
import bathroom from '../assets/photos/bathroom.jpg';

const priceFaqs = [
  { q: 'Is there a minimum booking?', a: 'Yes — two hours minimum for hourly services (domestic and commercial). Fixed-price jobs (deep, end-of-tenancy, after-builders) are priced per property with no minimum.' },
  { q: 'Are weekend rates higher?', a: 'No. Saturday and Sunday are standard rates. No weekend surcharge, no bank-holiday surcharge, no late-evening surcharge.' },
  { q: 'Do you charge travel?', a: 'Not within our 17-town service area around Oldham, Rochdale and Tameside. If you\'re just outside, ask — we often still cover it at no extra cost.' },
  { q: 'When do I pay?', a: 'For one-off cleans: on completion, same day. For regular domestic work: weekly or fortnightly, whichever matches your schedule. Commercial contracts: monthly invoice, 7-day terms.' },
  { q: 'Do you ever charge a call-out fee?', a: 'No. The quoted price is what you pay — we don\'t load hidden fees or "materials charges".' },
];

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Pricing', url: `${site.url}/pricing/` },
  ]),
  faqSchema(priceFaqs),
];
---
<Page
  title="Cleaning Prices in Oldham | Transparent Rates | Omni Shine"
  description="Clear, transparent cleaning prices. Domestic from £18/hr, commercial from £22/hr, end-of-tenancy from £180, deep cleans from £150. No hidden fees."
  path="/pricing/"
  schemas={schemas}
>
  <!-- Hero band -->
  <section class="relative isolate overflow-hidden text-white">
    <Image
      src={bathroom}
      alt=""
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      quality={70}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/85 to-navy-700/80"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 md:pb-20">
      <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Pricing'}]} />
      <div class="mt-6 max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30">Transparent pricing</p>
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-balance drop-shadow-md">Cleaning prices in Oldham</h1>
        <p class="mt-5 text-lg md:text-xl text-slate-100/95 text-balance drop-shadow leading-relaxed">Most cleaners hide behind "request a quote" — we don't. Here's exactly what we charge across Oldham, Rochdale and Tameside.</p>
      </div>
    </div>
  </section>

  <!-- Pricing table — full width -->
  <section class="mx-auto max-w-7xl px-4 py-16">
    <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
      <table class="w-full text-left">
        <thead class="bg-navy-950 text-white">
          <tr>
            <th class="p-4 text-sm font-semibold">Service</th>
            <th class="p-4 text-sm font-semibold">From</th>
            <th class="p-4 text-sm font-semibold hidden sm:table-cell">Unit</th>
          </tr>
        </thead>
        <tbody class="text-slate-800">
          {site.services.map(s => (
            <tr class="border-t border-slate-200 hover:bg-slate-50 transition">
              <td class="p-4">
                <a href={`/services/${s.slug}/`} class="font-semibold text-navy-900 hover:underline">{s.name}</a>
                <div class="mt-0.5 text-xs text-slate-500">{s.blurb}</div>
              </td>
              <td class="p-4 font-semibold text-lg">£{s.from}</td>
              <td class="p-4 text-sm text-slate-600 hidden sm:table-cell">{s.unit}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="font-display text-xl text-navy-900">What's always included</h2>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-700">
          <li class="flex items-start gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>Eco-friendly products and equipment</li>
          <li class="flex items-start gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>No weekend or bank-holiday surcharge</li>
          <li class="flex items-start gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>Same cleaner each visit (where possible)</li>
          <li class="flex items-start gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>72-hour re-clean on any missed areas</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="font-display text-xl text-navy-900">Payment methods</h2>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-700">
          {site.paymentsAccepted.map(p => (
            <li class="flex items-start gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>{p}</li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-slate-500">Commercial invoices on 7-day terms.</p>
      </div>
    </div>

    <h2 class="mt-16 font-display text-3xl text-navy-900 text-center">Pricing FAQs</h2>
    <div class="mt-8 mx-auto max-w-3xl divide-y divide-slate-200 border-y border-slate-200">
      {priceFaqs.map(f => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy-900">
            <span>{f.q}</span>
            <span aria-hidden="true" class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-slate-300 text-slate-500 transition group-open:rotate-45">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <p class="mt-3 text-slate-700">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Full-width quote form -->
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white py-20">
    <div class="absolute inset-0 opacity-25 pointer-events-none" aria-hidden="true">
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gold-400 blur-3xl rounded-full translate-y-1/2 -translate-x-1/3"></div>
    </div>
    <div class="relative mx-auto max-w-5xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl">Get an exact quote</h2>
        <p class="mt-4 text-slate-200">The table shows starting prices — tell us your postcode and bedroom count for a fixed number.</p>
      </div>
      <div class="mt-10 rounded-3xl bg-white text-slate-900 p-6 md:p-10 shadow-2xl">
        <QuoteForm />
      </div>
    </div>
  </section>
</Page>
