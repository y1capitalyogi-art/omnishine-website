---
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { breadcrumbSchema, faqSchema } from '../lib/schema';

const priceFaqs = [
  { q: 'Is there a minimum booking?', a: 'Yes — two hours minimum for hourly services (domestic and commercial). Fixed-price jobs (deep, end-of-tenancy, after-builders) are priced per property with no minimum.' },
  { q: 'Are weekend rates higher?', a: 'No. Saturday and Sunday are standard rates. No weekend surcharge, no bank-holiday surcharge, no late-evening surcharge.' },
  { q: 'Do you charge travel?', a: 'Not within our 14-town service area around Oldham and Rochdale. If you\'re just outside, ask — we often still cover it at no extra cost.' },
  { q: 'When do I pay?', a: 'For one-off cleans: on completion, same day. For regular domestic work: weekly or fortnightly, whichever matches your schedule. Commercial contracts: monthly invoice, 7-day terms.' },
  { q: 'Do you ever charge a call-out fee?', a: 'No. The quoted price is what you pay — we don\'t load hidden fees or "materials charges".' },
];

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Pricing', url: `${site.url}/pricing/` },
  ]),
  faqSchema(priceFaqs),
];
---
<Page
  title="Cleaning Prices in Oldham | Transparent Rates | Omni Shine"
  description="Clear, transparent cleaning prices in Oldham. Domestic from £18/hr, commercial from £22/hr, end-of-tenancy from £180, deep cleans from £150. No hidden fees."
  path="/pricing/"
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Pricing'}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">Transparent pricing</span>
    <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900">Cleaning prices in Oldham</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">Most cleaners hide behind "request a quote" — we don't. Here's exactly what we charge across Oldham and the 13 towns we serve.</p>

    <div class="mt-10 overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
      <table class="w-full text-left">
        <thead class="bg-navy-950 text-white">
          <tr>
            <th class="p-4 text-sm font-semibold">Service</th>
            <th class="p-4 text-sm font-semibold">From</th>
            <th class="p-4 text-sm font-semibold hidden sm:table-cell">Unit</th>
          </tr>
        </thead>
        <tbody class="text-slate-800">
          {site.services.map(s => (
            <tr class="border-t border-slate-200 hover:bg-slate-50">
              <td class="p-4">
                <a href={`/services/${s.slug}/`} class="font-semibold text-navy-900 hover:underline">{s.name}</a>
                <div class="mt-0.5 text-xs text-slate-500">{s.blurb}</div>
              </td>
              <td class="p-4 font-semibold">£{s.from}</td>
              <td class="p-4 text-sm text-slate-600 hidden sm:table-cell">{s.unit}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <div class="rounded-xl border border-slate-200 p-5">
        <h2 class="font-semibold text-navy-900">What's always included</h2>
        <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
          <li>✦ Eco-friendly products and equipment</li>
          <li>✦ No weekend or bank-holiday surcharge</li>
          <li>✦ Same cleaner each visit (where possible)</li>
          <li>✦ 72-hour re-clean on any missed areas</li>
        </ul>
      </div>
      <div class="rounded-xl border border-slate-200 p-5">
        <h2 class="font-semibold text-navy-900">Payment methods</h2>
        <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
          {site.paymentsAccepted.map(p => <li>✦ {p}</li>)}
        </ul>
      </div>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Pricing FAQs</h2>
    <div class="mt-4 divide-y divide-slate-200 border-y border-slate-200">
      {priceFaqs.map(f => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy-900">
            <span>{f.q}</span>
            <span aria-hidden="true" class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-slate-300 text-slate-500 transition group-open:rotate-45">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <p class="mt-3 text-slate-700">{f.a}</p>
        </details>
      ))}
    </div>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Get an exact quote for your property</h2>
      <p class="mt-2 text-slate-600">The table shows starting prices — tell us your postcode and bedroom count for a fixed number.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
