---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Uppermill';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Uppermill, Saddleworth | From £18/hr | Omni Shine`}
  description={`Cleaning in Uppermill — domestic, holiday-let turnovers and deep cleans for stone cottages and canal-side properties. Family-run, free quotes.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      <strong>Uppermill</strong> is the heart of Saddleworth — narrowboats on the Huddersfield Narrow Canal, the museum at Brownhill, weekenders coming up from Manchester. We clean homes here every week and turn over plenty of holiday lets along New Street and around the canal basin.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Holiday-let turnover cleans</h2>
    <p class="mt-4 text-slate-700">Uppermill has the densest holiday-let market in the borough, mostly serving walkers and Manchester weekenders. We do same-day turnovers between guests — fresh linen on request (bring-your-own or we arrange), restocking of basics, and photo confirmation when the property is guest-ready.</p>

    <h2 class="mt-10 font-display text-2xl text-navy-900">Period stone cottages</h2>
    <p class="mt-4 text-slate-700">A lot of homes here have flagstone floors, sandblasted stone walls and original Yorkshire-stone fireplaces. We use pH-neutral cleaners on these surfaces and test in a hidden spot before going ahead. Modern apartments along the canal get the standard domestic treatment.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700">Greenfield, Delph, Dobcross, Saddleworth, Springhead — <a href="/areas/" class="underline hover:text-navy-900">see all areas</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
