---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Uppermill';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Saddleworth villages"
  title={`Cleaners in Uppermill, Saddleworth | From £18/hr | Omni Shine`}
  description={`Cleaning in Uppermill — domestic, holiday-let turnovers and deep cleans for stone cottages and canal-side properties. Family-run, free quotes.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Stone cottage in the Saddleworth Pennines near Uppermill"
  intro="Uppermill is the heart of Saddleworth — narrowboats on the Huddersfield Narrow Canal, the museum at Brownhill, weekenders coming up from Manchester. We clean homes here every week and turn over plenty of holiday lets along New Street and around the canal basin."
>
  <h2 class="font-display text-2xl text-navy-900">Holiday-let turnover cleans</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Uppermill has the densest holiday-let market in the borough, mostly serving walkers and Manchester weekenders. We do same-day turnovers between guests — fresh linen on request (bring-your-own or we arrange), restocking of basics, and photo confirmation when the property is guest-ready.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Period stone cottages</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A lot of homes here have flagstone floors, sandblasted stone walls and original Yorkshire-stone fireplaces. We use pH-neutral cleaners on these surfaces and test in a hidden spot before going ahead. Modern apartments along the canal get the standard domestic treatment.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Saddleworth-specific service pages</h3>
    <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
      <li>✦ <a href="/services/end-of-tenancy-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">End-of-tenancy in Saddleworth</a></li>
      <li>✦ <a href="/services/deep-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">Deep cleaning in Saddleworth</a></li>
    </ul>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/greenfield/" class="underline hover:text-navy-900">Greenfield</a>,
    <a href="/areas/delph/" class="underline hover:text-navy-900">Delph</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth (hub)</a>,
    <a href="/areas/grotton/" class="underline hover:text-navy-900">Grotton</a>,
    <a href="/areas/mossley/" class="underline hover:text-navy-900">Mossley</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
