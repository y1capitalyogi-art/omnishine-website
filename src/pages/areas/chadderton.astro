---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import livingRoom from '../../assets/photos/living-room.jpg';

const area = 'Chadderton';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham borough"
  title={`Cleaners in Chadderton | £18/hr Weekly | Omni Shine`}
  description={`Domestic, commercial and end-of-tenancy cleaners in Chadderton, Hollinwood, Broadway and Mills Hill — £18/hr, eco-friendly, fast turnarounds for landlords.`}
  schemas={schemas}
  image={livingRoom}
  imageAlt="Bright modern home in Chadderton, freshly cleaned"
  intro="We clean homes, offices and rentals across Chadderton, Hollinwood, Broadway and Mills Hill — a quick run off the A627(M) from our base. Whether it's a weekly top-over, a post-tenant turnover, or a deep refresh before you sell, we turn up on time and do it properly."
>
  <h2 class="font-display text-2xl text-navy-900">Chadderton landlords and letting agents</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">We run a lot of <a href="/services/end-of-tenancy-cleaning-oldham/" class="underline hover:text-navy-900">end-of-tenancy work</a> along the Chadderton–Failsworth corridor. Fixed prices, detailed inventory-standard checklists, and a free 72-hour re-clean if your check-out inventory clerk flags anything.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Mills Hill and Broadway</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A short hop from the M60 means we can get to Mills Hill and Broadway addresses without travel charges. Most of our recurring Chadderton domestic clients are booked on Mondays or Wednesdays.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/failsworth/" class="underline hover:text-navy-900">Failsworth</a>,
    <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>,
    <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
