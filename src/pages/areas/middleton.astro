---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import livingRoom from '../../assets/photos/living-room.jpg';

const area = 'Middleton';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Rochdale borough"
  title={`Cleaners in Middleton | Family Homes £18/hr | Omni Shine`}
  description={`Trusted cleaners in Middleton, Alkrington, Rhodes, Boarshaw and Langley — £18/hr weekly, multi-cleaner teams for HMOs, eco-friendly products, weekends included.`}
  schemas={schemas}
  image={livingRoom}
  imageAlt="Bright modern Middleton living room interior"
  intro="Middleton is one of the larger towns in our extended service area — sitting right on the M60 between Oldham and Manchester. We cover the whole borough: Alkrington, Rhodes, Boarshaw, Langley and the Middleton town centre. Family homes, retail and office cleaning, plus a steady stream of end-of-tenancy work."
>
  <h2 class="font-display text-2xl text-navy-900">Travel and timing</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Middleton is just off the M60 from us. To keep travel time low we batch Middleton bookings on specific evenings — typically Wednesdays and Fridays — and you'll get the day that suits the slot we already have running. No travel surcharge within the borough.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Family-run, with the same person each visit</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">For weekly and fortnightly clients, we keep the same cleaner on your job. After two or three visits they know your routines and your house — which is the whole point of paying for a regular service rather than booking ad-hoc each time.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Middleton-specific service page</h3>
    <p class="mt-2 text-sm text-slate-700">For landlords, students and turnovers: <a href="/services/end-of-tenancy-cleaning-middleton/" class="font-semibold underline hover:text-navy-900">end-of-tenancy cleaning page for Middleton</a>. Fixed prices from £180 with a 72-hour re-clean guarantee.</p>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/chadderton/" class="underline hover:text-navy-900">Chadderton</a>,
    <a href="/areas/failsworth/" class="underline hover:text-navy-900">Failsworth</a>,
    <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>,
    <a href="/areas/rochdale/" class="underline hover:text-navy-900">Rochdale</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
