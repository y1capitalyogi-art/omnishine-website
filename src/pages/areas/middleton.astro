---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Middleton';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Middleton, Manchester | From £18/hr | Omni Shine`}
  description={`Reliable home, commercial and end-of-tenancy cleaning in Middleton — Alkrington, Rhodes, Boarshaw, Langley. Family-run, eco-friendly, free quotes.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      <strong>Middleton</strong> is one of the larger towns in our extended service area — sitting right on the M60 between Oldham and Manchester. We cover the whole borough: <strong>Alkrington, Rhodes, Boarshaw, Langley</strong> and the Middleton town centre. Family homes, retail and office cleaning, plus a steady stream of end-of-tenancy work.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Travel and timing</h2>
    <p class="mt-4 text-slate-700">Middleton is just off the M60 from us. To keep travel time low we batch Middleton bookings on specific evenings — typically Wednesdays and Fridays — and you'll get the day that suits the slot we already have running. No travel surcharge within the borough.</p>

    <h2 class="mt-10 font-display text-2xl text-navy-900">Family-run, with the same person each visit</h2>
    <p class="mt-4 text-slate-700">For weekly and fortnightly clients, we keep the same cleaner on your job. After two or three visits they know your routines and your house — which is the whole point of paying for a regular service rather than booking ad-hoc each time.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700"><a href="/areas/chadderton/" class="underline hover:text-navy-900">Chadderton</a>, <a href="/areas/failsworth/" class="underline hover:text-navy-900">Failsworth</a>, <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>, <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>, <a href="/areas/rochdale/" class="underline hover:text-navy-900">Rochdale</a> — <a href="/areas/" class="underline hover:text-navy-900">see all areas</a>.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">High-intent services in {area}</h2>
    <ul class="mt-3 space-y-2 text-slate-700">
      <li>✦ <a href="/services/end-of-tenancy-cleaning-oldham/" class="underline hover:text-navy-900">End of tenancy cleaning</a> from £180 fixed</li>
      <li>✦ <a href="/services/deep-cleaning-oldham/" class="underline hover:text-navy-900">Deep cleaning</a> from £150 fixed</li>
      <li>✦ <a href="/services/commercial-cleaning-oldham/" class="underline hover:text-navy-900">Commercial cleaning</a> from £22/hr</li>
    </ul>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
