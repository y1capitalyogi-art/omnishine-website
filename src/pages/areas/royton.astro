---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import livingRoom from '../../assets/photos/living-room.jpg';

const area = 'Royton';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham borough"
  title={`Cleaners in Royton, Oldham | From £18/hr | Omni Shine`}
  description={`Reliable domestic, commercial and deep cleaning in Royton and Thornham. From £18/hr, eco-friendly, weekends included. Free local quotes.`}
  schemas={schemas}
  image={livingRoom}
  imageAlt="Bright Royton family home interior — clean and ready for the weekend"
  intro="We cover Royton, Heyside and Thornham weekly — from the Royton town centre out to Luzley Brook. Domestic cleaning from £18/hr, commercial from £22/hr, and fixed-price deep and end-of-tenancy cleans from £150 and £180."
>
  <h2 class="font-display text-2xl text-navy-900">Why Royton households book us</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A lot of the Royton homes we clean are family houses that need someone reliable week-in, week-out — we prioritise continuity so you get the same cleaner each visit and we learn your routines. Evenings and weekends included at no surcharge.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Royton-specific page</h3>
    <p class="mt-2 text-sm text-slate-700">For working families: see our dedicated <a href="/services/domestic-cleaning-royton/" class="font-semibold underline hover:text-navy-900">domestic cleaning page for Royton</a>. Same £18/hr, weekly and fortnightly slots, same cleaner each visit.</p>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/shaw/" class="underline hover:text-navy-900">Shaw</a>,
    <a href="/areas/chadderton/" class="underline hover:text-navy-900">Chadderton</a>,
    <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>,
    <a href="/areas/rochdale/" class="underline hover:text-navy-900">Rochdale</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
