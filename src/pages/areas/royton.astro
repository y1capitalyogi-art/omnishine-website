---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Royton';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Royton, Oldham | From £18/hr | Omni Shine`}
  description={`Reliable domestic, commercial and deep cleaning in Royton and Thornham. From £18/hr, eco-friendly, weekends included. Free local quotes.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      We cover <strong>Royton, Heyside and Thornham</strong> weekly — from the Royton town centre out to Luzley Brook. Domestic cleaning from £18/hr, commercial from £22/hr, and fixed-price deep and end-of-tenancy cleans from £150 and £180 respectively.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Why {area} households book us</h2>
    <p class="mt-4 text-slate-700">A lot of Royton homes we clean are family houses that need someone reliable week-in, week-out — we prioritise continuity so you get the same cleaner each visit and we learn your routines. Evenings and weekends included at no surcharge.</p>

    <div class="mt-6 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
      <h3 class="font-semibold text-navy-900">Royton-specific page</h3>
      <p class="mt-2 text-sm text-slate-700">For working families: see our dedicated <a href="/services/domestic-cleaning-royton/" class="font-semibold underline hover:text-navy-900">domestic cleaning page for Royton</a>. Same £18/hr, weekly and fortnightly slots, same cleaner each visit.</p>
    </div>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700"><a href="/areas/shaw/" class="underline hover:text-navy-900">Shaw</a>, <a href="/areas/chadderton/" class="underline hover:text-navy-900">Chadderton</a>, <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a>, <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>, <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>, <a href="/areas/rochdale/" class="underline hover:text-navy-900">Rochdale</a> — <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <p class="mt-2 text-slate-600">Short form, fast reply during opening times.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
