---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Mossley';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Tameside borough"
  title={`Cleaners in Mossley, Tameside | From £18/hr | Omni Shine`}
  description={`Cleaning in Mossley — stone-cottage friendly, holiday-let turnovers, end-of-tenancy and weekly domestic. Family-run, eco-friendly, free quotes.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Bright, freshly cleaned bathroom in a Mossley stone cottage"
  intro="Mossley is a small Pennine town on the canal — old mill heritage, stone-built terraces, a steep main street. It has a real Saddleworth-side character: stone cottages, exposed beams, and a holiday-let scene that rivals Uppermill. We cover all of Mossley plus the surrounding areas of Micklehurst and Carrbrook."
>
  <h2 class="font-display text-2xl text-navy-900">Stone-cottage friendly</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Many Mossley homes are old stone-built mill workers' cottages — flagstone hallways, exposed beams, original Yorkshire-stone fireplaces. We use pH-neutral cleaners on stone and never abrasive scrubs. Our <a href="/services/deep-cleaning-saddleworth/" class="underline hover:text-navy-900">Saddleworth-style deep clean</a> is particularly popular here for spring refreshes.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Holiday-let owners</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">If you run an Airbnb or short-let in Mossley, we do same-day turnovers between guests — fresh linen on request, restocking of basics, photo confirmation when guest-ready. The same approach we use for our <a href="/services/end-of-tenancy-cleaning-saddleworth/" class="underline hover:text-navy-900">Saddleworth holiday-let work</a>.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Travel and timing</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Mossley is at the edge of our service area. We batch Mossley bookings with our Saddleworth and Ashton runs — you'll be offered the day that lines up with the slot already running. No travel surcharge within Mossley itself.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/uppermill/" class="underline hover:text-navy-900">Uppermill</a>,
    <a href="/areas/greenfield/" class="underline hover:text-navy-900">Greenfield</a>,
    <a href="/areas/ashton-under-lyne/" class="underline hover:text-navy-900">Ashton-under-Lyne</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
