---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Grotton';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Saddleworth villages"
  title={`Cleaners in Grotton, Oldham | Quiet Village £18/hr`}
  description={`Reliable home cleaning in Grotton between Lees and Springhead. £18/hr weekly or fortnightly, same cleaner every visit, no last-minute substitutions.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Bright, freshly cleaned bathroom in a Grotton home"
  intro="Grotton is a small, quiet residential village tucked between Lees and Springhead — the kind of place where most clients want one reliable cleaner who shows up every fortnight without drama. We handle Grotton on the same evenings we cover Lees and Springhead, so we can usually offer same-week starts."
>
  <h2 class="font-display text-2xl text-navy-900">Small village, careful service</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">In a village this size, word travels fast — both the good and the bad. We treat every Grotton booking as a long-term reputation play. Same cleaner every visit, no last-minute substitutions, and a quick follow-up text after the first clean to check we've got everything right.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Pricing held simple</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">£18/hr for domestic, two-hour minimum, no travel surcharge for Grotton, no weekend uplift. Fixed quotes for one-off deep and end-of-tenancy work — see the <a href="/pricing/" class="underline hover:text-navy-900">pricing page</a> for full details.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/lees/" class="underline hover:text-navy-900">Lees</a>,
    <a href="/areas/springhead/" class="underline hover:text-navy-900">Springhead</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/uppermill/" class="underline hover:text-navy-900">Uppermill</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
