---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import heroHome from '../../assets/photos/hero-home.jpg';

const area = 'Shaw';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham borough"
  title={`Cleaners in Shaw, Oldham | From £18/hr | Omni Shine`}
  description={`Domestic, commercial and deep cleaning in Shaw and Crompton from £18/hr. Family-run, eco-friendly, weekends included. Free quotes within two working hours.`}
  schemas={schemas}
  image={heroHome}
  imageAlt="Bright family home interior in Shaw"
  intro="Omni Shine covers Shaw and Crompton every week — from Buckstones Road through Beal Vale and out to High Crompton. Domestic cleaning from £18/hr, end-of-tenancy from £180, and deep cleans from £150, with the same cleaner each visit wherever possible."
>
  <h2 class="font-display text-2xl text-navy-900">Slots that fit Shaw schedules</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A lot of Shaw clients book Tuesday or Friday evenings — if that suits you, ask on the form and we'll likely have a slot. Saturday mornings fill fastest. We batch Shaw with Royton on the same evenings, which keeps travel low and slots reliable.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Family homes, the same cleaner each visit</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">For weekly and fortnightly clients we keep the same cleaner on your job. After two or three visits they know which cupboards hold what, how you like the towels folded, and which surfaces want extra care.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>,
    <a href="/areas/chadderton/" class="underline hover:text-navy-900">Chadderton</a>,
    <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>,
    <a href="/areas/rochdale/" class="underline hover:text-navy-900">Rochdale</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
