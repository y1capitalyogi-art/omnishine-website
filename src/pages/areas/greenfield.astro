---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Greenfield';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Saddleworth villages"
  title={`Cleaners in Greenfield, Saddleworth | From £18/hr | Omni Shine`}
  description={`Cleaning for homes and Airbnb holiday lets in Greenfield, near Dovestone Reservoir. Stone-cottage friendly, same-day turnovers, free quotes.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Greenfield Pennine countryside near Dovestone Reservoir"
  intro="Greenfield sits at the foot of Dovestone Reservoir — popular with walkers, climbers, and weekend escape-from-the-city visitors. That brings two distinct kinds of work: weekly and fortnightly cleans for the resident families, and same-day turnovers for the Airbnb and short-let cottages along Manchester Road and up Chew Valley."
>
  <h2 class="font-display text-2xl text-navy-900">Holiday-let owners — we're built for fast turnovers</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">If you run an Airbnb in Greenfield, you know the brief: 3-hour turnaround windows, fresh linen, restocked basics, photo-confirmation when the property is guest-ready. We do this regularly. If a guest leaves the property in an unexpected state, we tell you with photos before doing anything that might affect a damage claim.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Stone-cottage friendly</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Many Greenfield properties are old Yorkshire-stone cottages with flagstone floors and exposed beams. We use pH-neutral cleaners, soft brushes on stone, and never abrasive scrubs. Modern build-outs along New Tame get the standard domestic treatment.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Greenfield-relevant pages</h3>
    <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
      <li>✦ <a href="/services/deep-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">Deep cleaning in Saddleworth</a> — for stone-cottage refreshes</li>
      <li>✦ <a href="/services/end-of-tenancy-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">End-of-tenancy / holiday-let turnovers</a></li>
    </ul>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/uppermill/" class="underline hover:text-navy-900">Uppermill</a>,
    <a href="/areas/delph/" class="underline hover:text-navy-900">Delph</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/mossley/" class="underline hover:text-navy-900">Mossley</a>,
    <a href="/areas/grotton/" class="underline hover:text-navy-900">Grotton</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
