---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Saddleworth';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Saddleworth villages"
  title={`Cleaners in Saddleworth | Uppermill, Greenfield, Delph | Omni Shine`}
  description={`Trusted cleaners across the Saddleworth villages — Uppermill, Greenfield, Delph, Dobcross, Diggle. Domestic, deep and end-of-tenancy from £18/hr.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Saddleworth-style English stone cottage in the Pennine landscape"
  intro="We cover the Saddleworth villages — Uppermill, Greenfield, Delph, Dobcross, Diggle, Grotton and Springhead. Stone cottages, barn conversions, hillside houses — the Saddleworth jobs aren't always simple, and we love them for it."
>
  <h2 class="font-display text-2xl text-navy-900">Older homes, modern standards</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Flagstones, sandblasted stone, vintage fireplaces — we use products suitable for old surfaces and always test in an inconspicuous spot first. If something isn't right for your home, we say so.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Holiday-let owners in Saddleworth</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Same-day turnover cleans for Airbnb and short-let properties across Uppermill and Greenfield. Fresh linen on request (bring-your-own or we arrange), restocking of basics, and photo-confirmation when the property is ready for the next guest.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Saddleworth-specific service pages</h3>
    <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
      <li>✦ <a href="/services/end-of-tenancy-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">End-of-tenancy cleaning in Saddleworth</a> — long-let inventory standard or holiday-let turnover</li>
      <li>✦ <a href="/services/deep-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">Deep cleaning in Saddleworth</a> — careful with period stone and exposed beams</li>
    </ul>
  </div>

  <h2 slot="after-services" class="mt-12 font-display text-2xl text-navy-900">Specific Saddleworth villages we cover</h2>
  <ul slot="after-services" class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
    <li>✦ <a href="/areas/uppermill/" class="underline hover:text-navy-900">Cleaners in Uppermill</a></li>
    <li>✦ <a href="/areas/greenfield/" class="underline hover:text-navy-900">Cleaners in Greenfield</a></li>
    <li>✦ <a href="/areas/delph/" class="underline hover:text-navy-900">Cleaners in Delph</a></li>
    <li>✦ <a href="/areas/grotton/" class="underline hover:text-navy-900">Cleaners in Grotton</a></li>
    <li>✦ <a href="/areas/springhead/" class="underline hover:text-navy-900">Cleaners in Springhead</a></li>
    <li>✦ <a href="/areas/mossley/" class="underline hover:text-navy-900">Cleaners in Mossley</a></li>
  </ul>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/lees/" class="underline hover:text-navy-900">Lees</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>,
    <a href="/areas/ashton-under-lyne/" class="underline hover:text-navy-900">Ashton-under-Lyne</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
