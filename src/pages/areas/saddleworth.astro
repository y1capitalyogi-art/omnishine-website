---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Saddleworth';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Saddleworth | Uppermill, Greenfield, Delph | Omni Shine`}
  description={`Trusted cleaners across the Saddleworth villages — Uppermill, Greenfield, Delph, Dobcross, Diggle. Domestic, deep and end-of-tenancy from £18/hr.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in Saddleworth</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      We cover the <strong>Saddleworth villages</strong> — Uppermill, Greenfield, Delph, Dobcross, Diggle, Grotton and Springhead. Stone cottages, barn conversions, hillside houses — the Saddleworth jobs aren't always simple, and we love them for it.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services in the Saddleworth villages</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Older homes, modern standards</h2>
    <p class="mt-4 text-slate-700">Flagstones, sandblasted stone, vintage fireplaces — we use products suitable for old surfaces and always test in an inconspicuous spot first. If something isn't right for your home, we say so.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Holiday-let owners in Saddleworth</h2>
    <p class="mt-4 text-slate-700">Same-day turnover cleans for Airbnb and short-let properties. Fresh linen on request (bring-your-own or we arrange), restocking of basics, and photo-confirmation when the property is ready for the next guest.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700">Uppermill, Greenfield, Grotton, Delph, Springhead, Lees — <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} towns</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for Saddleworth</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
