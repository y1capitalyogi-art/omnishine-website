---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Lees';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Lees, Oldham | From £18/hr | Omni Shine`}
  description={`Stone-cottage and modern home cleaning in Lees and Springhead. Domestic, deep and end-of-tenancy cleaning. Family-run, eco-friendly, free quotes.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      <strong>Lees</strong> sits on the A669 between Oldham town and Saddleworth, with a real mix of housing — old stone terraces along High Street, post-war semis up Thomas Street, and modern infill developments off St John's Road. We clean across all of it weekly and fortnightly.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Older homes get a careful approach</h2>
    <p class="mt-4 text-slate-700">A lot of Lees properties have original features — flagstone hallways, exposed beams, period tiling. We test products in an inconspicuous spot first and use pH-neutral cleaners on stone, never abrasive scrubs. If we're not sure something will react well, we ask before we clean.</p>

    <h2 class="mt-10 font-display text-2xl text-navy-900">Quick access from our base</h2>
    <p class="mt-4 text-slate-700">Lees is a 5-minute drive from our usual run, which means same-week slots and zero travel surcharge. We typically batch Lees, Springhead and Grotton bookings on the same evenings.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700">Springhead, Grotton, Saddleworth, Oldham, Moorside — <a href="/areas/" class="underline hover:text-navy-900">see all areas</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
