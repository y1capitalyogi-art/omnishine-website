---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import bathroom from '../../assets/photos/bathroom.jpg';

const area = 'Lees';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham borough"
  title={`Cleaners in Lees, Oldham | From £18/hr | Omni Shine`}
  description={`Stone-cottage and modern home cleaning in Lees and Springhead. Domestic, deep and end-of-tenancy cleaning. Family-run, eco-friendly, free quotes.`}
  schemas={schemas}
  image={bathroom}
  imageAlt="Spotless modern bathroom after a Lees deep clean"
  intro="Lees sits on the A669 between Oldham town and Saddleworth, with a real mix of housing — old stone terraces along High Street, post-war semis up Thomas Street, and modern infill developments off St John's Road. We clean across all of it weekly and fortnightly."
>
  <h2 class="font-display text-2xl text-navy-900">Older homes get a careful approach</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A lot of Lees properties have original features — flagstone hallways, exposed beams, period tiling. We test products in an inconspicuous spot first and use pH-neutral cleaners on stone, never abrasive scrubs. If we're not sure something will react well, we ask before we clean.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Quick access from our base</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Lees is a 5-minute drive from our usual run, which means same-week slots and zero travel surcharge. We typically batch Lees, Springhead and Grotton bookings on the same evenings.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/springhead/" class="underline hover:text-navy-900">Springhead</a>,
    <a href="/areas/grotton/" class="underline hover:text-navy-900">Grotton</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
