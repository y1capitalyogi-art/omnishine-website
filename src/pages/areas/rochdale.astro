---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import kitchen from '../../assets/photos/kitchen.jpg';

const area = 'Rochdale';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Rochdale borough"
  title={`Cleaners in Rochdale | Domestic & EOT £18/hr`}
  description={`Reliable cleaners in Rochdale — town centre, Castleton, Norden, Spotland, Milnrow. Domestic £18/hr, EOT £180, deep £150. Same cleaner each visit, weekends included.`}
  schemas={schemas}
  image={kitchen}
  imageAlt="Sparkling clean Rochdale rental property kitchen"
  intro="We cross the M62 regularly for Rochdale clients — covering the town centre, Castleton, Norden, Spotland, Milnrow and surrounding neighbourhoods. Weekly domestic from £18/hr, commercial from £22/hr, and fixed-quote deep and end-of-tenancy cleans."
>
  <h2 class="font-display text-2xl text-navy-900">Why Rochdale clients book us</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">We batch our Rochdale visits on specific days to keep travel overhead low, which means reliable weekly slots without travel surcharges. Tell us your area of Rochdale and we'll match you to the day we're already nearby.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Rochdale-specific service page</h3>
    <p class="mt-2 text-sm text-slate-700">Big rental market in Rochdale — see our dedicated <a href="/services/end-of-tenancy-cleaning-rochdale/" class="font-semibold underline hover:text-navy-900">end-of-tenancy cleaning page for Rochdale</a>. Fixed prices from £180, 72-hour re-clean guarantee, set up for HMOs, student lets, and family rentals.</p>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/shaw/" class="underline hover:text-navy-900">Shaw</a>,
    <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>,
    <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
