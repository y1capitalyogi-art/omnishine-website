---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Rochdale';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Rochdale | Domestic, Commercial, End-of-Tenancy | Omni Shine`}
  description={`Reliable cleaners in Rochdale, covering the town centre, Castleton, Norden, Spotland and Milnrow. Family-run, eco-friendly, weekends included.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      We cross the M62 regularly for {area} clients — covering the town centre, Castleton, Norden, Spotland, Milnrow and surrounding neighbourhoods. Weekly domestic from £18/hr, commercial from £22/hr, and fixed-quote deep and end-of-tenancy cleans.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Why Rochdale clients book us</h2>
    <p class="mt-4 text-slate-700">We batch our Rochdale visits on specific days to keep travel overhead low, which means reliable weekly slots without travel surcharges. Tell us your area of Rochdale and we'll match you to the day we're already nearby.</p>

    <div class="mt-6 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
      <h3 class="font-semibold text-navy-900">Rochdale-specific service page</h3>
      <p class="mt-2 text-sm text-slate-700">Big rental market in Rochdale — see our dedicated <a href="/services/end-of-tenancy-cleaning-rochdale/" class="font-semibold underline hover:text-navy-900">end-of-tenancy cleaning page for Rochdale</a>. Fixed prices from £180, 72-hour re-clean guarantee, set up for HMOs, student lets, and family rentals.</p>
    </div>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700"><a href="/areas/shaw/" class="underline hover:text-navy-900">Shaw</a>, <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>, <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a>, <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>, <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a> — <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
