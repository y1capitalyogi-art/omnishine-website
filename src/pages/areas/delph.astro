---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Delph';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Saddleworth villages"
  title={`Cleaners in Delph | Conservation Cottages £18/hr`}
  description={`Careful cleaning for Delph's stone cottages and conservation-area homes — £18/hr, pH-neutral on flagstones, period-feature safe, weekend slots available.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Bright, freshly cleaned bathroom in a Delph cottage"
  intro="Delph sits in the Tame valley with the white-painted Co-op as its landmark — a tight-knit Saddleworth conservation village of stone cottages, narrow lanes and the old Brownhill Bridge. Almost every property here has period features that need a careful hand."
>
  <h2 class="font-display text-2xl text-navy-900">Conservation-area homes</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A lot of Delph cottages have flagstone floors, original Yorkshire-stone walls, period sashes and exposed beams. We use pH-neutral cleaners on stone, never abrasive scrubs, and always test in a hidden spot before applying anything new. If we're unsure a product is right for your floor, we ask before going ahead.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Narrow lanes, no problem</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Some Delph addresses are tricky to park near. Tell us your nearest landmark on the form and we'll figure out the best drop-off; we travel light enough to walk in from a sensible parking spot.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Best-fit services for Delph</h3>
    <ul class="mt-3 space-y-1.5 text-sm text-slate-700">
      <li>✦ <a href="/services/deep-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">Deep cleaning in Saddleworth</a></li>
      <li>✦ <a href="/services/end-of-tenancy-cleaning-saddleworth/" class="font-semibold underline hover:text-navy-900">End-of-tenancy / holiday-let in Saddleworth</a></li>
    </ul>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/uppermill/" class="underline hover:text-navy-900">Uppermill</a>,
    <a href="/areas/greenfield/" class="underline hover:text-navy-900">Greenfield</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/grotton/" class="underline hover:text-navy-900">Grotton</a>,
    <a href="/areas/mossley/" class="underline hover:text-navy-900">Mossley</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
