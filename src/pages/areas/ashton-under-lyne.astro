---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import office from '../../assets/photos/office.jpg';

const area = 'Ashton-under-Lyne';
const slug = 'ashton-under-lyne';
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  slug={slug}
  borough="Tameside borough"
  title={`Cleaners in Ashton-under-Lyne | £18/hr | Omni Shine`}
  description={`Cleaners across Ashton-under-Lyne, Hurst, Smallshaw and Hartshead — £18/hr domestic, fast EOT for HMOs near Tameside College, commercial £22/hr, evenings ok.`}
  schemas={schemas}
  image={office}
  imageAlt="Modern Ashton-under-Lyne office ready for the morning"
  intro="Ashton-under-Lyne sits in Tameside, a short hop from us via the M60. We cover the town centre, Hurst, Smallshaw, Hartshead and out toward Mossley — domestic cleans for family homes, commercial work for offices and salons around the market hall, and a steady book of end-of-tenancy work for the student and HMO market near Tameside College."
>
  <h2 class="font-display text-2xl text-navy-900">Big rental market, fast turnarounds</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Ashton has a substantial rental market — student housing near Tameside College, HMOs, terraced lets across Hurst and Hartshead. We're set up for fast turnovers between tenants: same-day starts at the weekend, multi-cleaner teams for larger properties, and our standard 72-hour re-clean guarantee.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Travel and timing</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">We batch Ashton bookings on specific evenings to keep travel overhead low and deliver reliable weekly slots — typically Mondays and Saturdays. No travel surcharge within Ashton itself.</p>

  <div class="mt-8 rounded-xl border border-gold-400/40 bg-gold-400/10 p-5">
    <h3 class="font-semibold text-navy-900">Ashton-specific service page</h3>
    <p class="mt-2 text-sm text-slate-700">Independent salons, café fit-outs and offices around Stamford Street: see <a href="/services/commercial-cleaning-ashton-under-lyne/" class="font-semibold underline hover:text-navy-900">commercial cleaning in Ashton-under-Lyne</a> from £22/hr — evenings, weekends, monthly invoicing.</p>
  </div>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/mossley/" class="underline hover:text-navy-900">Mossley</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/failsworth/" class="underline hover:text-navy-900">Failsworth</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
