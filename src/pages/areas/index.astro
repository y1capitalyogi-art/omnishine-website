---
import { Image } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AreaCard from '../../components/AreaCard.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas we cover', url: `${site.url}/areas/` },
])];

const groups = [
  { label: 'Oldham borough', areas: ['Oldham','Shaw','Royton','Chadderton','Failsworth','Lees','Moorside'] },
  { label: 'Saddleworth villages', areas: ['Saddleworth','Uppermill','Greenfield','Delph','Springhead','Grotton'] },
  { label: 'Rochdale borough', areas: ['Rochdale','Middleton'] },
  { label: 'Tameside borough', areas: ['Ashton-under-Lyne','Mossley'] },
];
---
<Page
  title="Cleaning Service Areas | 17 Towns Around Oldham"
  description="We cover 17 towns across Oldham, Rochdale and Tameside boroughs — Saddleworth villages, family homes, rentals. Click your area for local rates and slots."
  path="/areas/"
  schemas={schemas}
>
  <!-- Hero band -->
  <section class="relative isolate overflow-hidden text-white">
    <Image
      src={stoneCottage}
      alt=""
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      quality={70}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/85 to-navy-700/80"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 md:pb-20">
      <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas we cover'}]} />
      <div class="mt-6 max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30">Coverage</p>
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-balance drop-shadow-md">Areas we cover</h1>
        <p class="mt-5 text-lg md:text-xl text-slate-100/95 text-balance drop-shadow leading-relaxed">{site.areas.length} towns across Oldham, Rochdale and Tameside boroughs. Click any area for local detail — or skip ahead and get a free quote.</p>
      </div>
    </div>
  </section>

  <!-- Areas grouped by borough -->
  <section class="mx-auto max-w-7xl px-4 py-14 md:py-20">
    {groups.map(g => (
      <div class="mb-12">
        <h2 class="font-display text-2xl text-navy-900 mb-5 flex items-baseline gap-3">
          {g.label}
          <span class="text-sm font-normal text-slate-500">{g.areas.length} {g.areas.length === 1 ? 'town' : 'towns'}</span>
        </h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
          {g.areas.map(a => (
            <AreaCard
              href={`/areas/${a.toLowerCase()}/`}
              name={a}
              hasPage={(site.areaPages as readonly string[]).includes(a)}
            />
          ))}
        </div>
      </div>
    ))}

    <div class="mt-12 rounded-2xl bg-slate-50 border border-slate-200 p-8 max-w-4xl">
      <h2 class="font-display text-xl text-navy-900">Not on the list?</h2>
      <p class="mt-2 text-slate-700">If you're just outside — Hyde, Stalybridge, Littleborough, Milnrow, Mossley — drop us a note. We often still cover these with no travel surcharge.</p>
    </div>
  </section>

  <!-- Full-width CTA -->
  <section id="quote" class="relative isolate overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white py-20">
    <div class="relative mx-auto max-w-5xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl">Get a free local quote</h2>
        <p class="mt-4 text-slate-200">Tell us your postcode — we'll confirm we cover you and send a price within two working hours.</p>
      </div>
      <div class="mt-10 rounded-3xl bg-white text-slate-900 p-6 md:p-10 shadow-2xl">
        <QuoteForm />
      </div>
    </div>
  </section>
</Page>
