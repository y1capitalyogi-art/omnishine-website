---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import stoneCottage from '../../assets/photos/stone-cottage.jpg';

const area = 'Springhead';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham / Saddleworth border"
  title={`Cleaners in Springhead, Oldham | From £18/hr | Omni Shine`}
  description={`Domestic and end-of-tenancy cleaning in Springhead. Family-run, eco-friendly, weekend slots, fast quotes within two working hours.`}
  schemas={schemas}
  image={stoneCottage}
  imageAlt="Freshly cleaned bathroom in a Springhead home"
  intro="Springhead sits between Oldham town and Saddleworth, a quiet residential village along Oldham Road and St John Street. Most of our Springhead clients book weekly or fortnightly domestic cleans — we batch the area with Lees and Grotton on the same evenings, which keeps slots reliable and travel time low."
>
  <h2 class="font-display text-2xl text-navy-900">Reliability is the whole point</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Springhead is a residential commuter village — most of our clients here are working families. The reason they pick us is that we turn up when we say we will. If we're going to be late, we tell you. If we can't make a slot, we rearrange properly. No silent no-shows.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Get the same cleaner each visit</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">For recurring cleans we keep the same cleaner on your job wherever possible. After a few visits they'll know which cupboards hold what, how you like the towels folded, and which surfaces need extra care.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/lees/" class="underline hover:text-navy-900">Lees</a>,
    <a href="/areas/grotton/" class="underline hover:text-navy-900">Grotton</a>,
    <a href="/areas/saddleworth/" class="underline hover:text-navy-900">Saddleworth</a>,
    <a href="/areas/uppermill/" class="underline hover:text-navy-900">Uppermill</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
