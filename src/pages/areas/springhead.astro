---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Springhead';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Springhead, Oldham | From £18/hr | Omni Shine`}
  description={`Domestic and end-of-tenancy cleaning in Springhead. Family-run, eco-friendly, weekend slots, fast quotes within two working hours.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      <strong>Springhead</strong> sits between Oldham town and Saddleworth, a quiet residential village along Oldham Road and St John Street. Most of our Springhead clients book weekly or fortnightly domestic cleans — we batch the area with Lees and Grotton on the same evenings, which keeps slots reliable and travel time low.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Reliability is the whole point</h2>
    <p class="mt-4 text-slate-700">Springhead is a residential commuter village — most of our clients here are working families. The reason they pick us is that we turn up when we say we will. If we're going to be late, we tell you. If we can't make a slot, we rearrange properly. No silent no-shows.</p>

    <h2 class="mt-10 font-display text-2xl text-navy-900">Get the same cleaner each visit</h2>
    <p class="mt-4 text-slate-700">For recurring cleans we keep the same cleaner on your job wherever possible. After a few visits they'll know which cupboards hold what, how you like the towels folded, and which surfaces need extra care.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700">Lees, Grotton, Saddleworth, Oldham, Uppermill — <a href="/areas/" class="underline hover:text-navy-900">see all areas</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
