---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import bathroom from '../../assets/photos/bathroom.jpg';

const area = 'Moorside';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham borough"
  title={`Cleaners in Moorside, Oldham | £18/hr Weekly`}
  description={`Domestic cleaning across Moorside, Ripponden Road and Higginshaw — £18/hr weekly. Same cleaner every visit, eco-friendly products, weekend slots, free quotes.`}
  schemas={schemas}
  image={bathroom}
  imageAlt="Spotless bathroom after a Moorside deep clean"
  intro="Moorside climbs the hill east of Oldham toward the Pennine moors — Ripponden Road, Roundthorn, Higginshaw. The housing stock is a mix: stone-fronted Victorian semis, post-war estates, and a few modern infill developments. We clean the lot, weekly and fortnightly."
>
  <h2 class="font-display text-2xl text-navy-900">Hilly streets, big windows</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">A lot of Moorside houses have full-height bay windows facing east — beautiful in the morning, dust-magnets the rest of the time. Interior glass and sills are part of every standard visit; full external window cleans we'll quote separately.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Mid-week evening slots</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">For Moorside we usually offer Tuesday or Thursday evenings on a regular schedule. Weekend slots fill fastest — get in touch as soon as you've decided you want one and we'll squeeze you into the next opening.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>,
    <a href="/areas/lees/" class="underline hover:text-navy-900">Lees</a>,
    <a href="/areas/failsworth/" class="underline hover:text-navy-900">Failsworth</a>,
    <a href="/areas/royton/" class="underline hover:text-navy-900">Royton</a>,
    <a href="/areas/springhead/" class="underline hover:text-navy-900">Springhead</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
