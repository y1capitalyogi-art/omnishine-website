---
import AreaPageLayout from '../../layouts/AreaPageLayout.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';
import kitchen from '../../assets/photos/kitchen.jpg';

const area = 'Failsworth';
const path = `/areas/${area.toLowerCase()}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<AreaPageLayout
  area={area}
  borough="Oldham borough"
  title={`Cleaners in Failsworth | From £18/hr | Omni Shine`}
  description={`Reliable domestic, commercial and end-of-tenancy cleaning in Failsworth and Hollinwood from £18/hr. Family-run, eco-friendly, fast quotes.`}
  schemas={schemas}
  image={kitchen}
  imageAlt="Cleaned Failsworth rental property kitchen"
  intro="We work right across Failsworth and Hollinwood — from Oldham Road through Holt Lane and out toward Newton Heath. Failsworth is one of our busiest patches: family homes near the cricket club, terraced rentals along the A62, and a steady stream of end-of-tenancy work for local landlords."
>
  <h2 class="font-display text-2xl text-navy-900">Failsworth landlords and letting agents</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">Failsworth has a very active rental market — terraced two-ups along the A62 corridor, modern flats nearer the Metrolink, and a lot of HMO conversions. We handle <a href="/services/end-of-tenancy-cleaning-oldham/" class="underline hover:text-navy-900">end-of-tenancy cleans</a> on tight notice (often turning a property in 24 hours between tenants), with the same fixed-price, inventory-standard checklist and 72-hour re-clean guarantee.</p>

  <h2 class="mt-12 font-display text-2xl text-navy-900">Family homes</h2>
  <p class="mt-4 text-slate-700 leading-relaxed">For domestic clients we run weekly and fortnightly slots in the Failsworth area on Tuesdays and Thursdays. Most of our recurring clients ask for the same cleaner each visit — we make that work wherever possible.</p>

  <p slot="nearby" class="mt-2 text-slate-700">
    <a href="/areas/chadderton/" class="underline hover:text-navy-900">Chadderton</a>,
    <a href="/areas/oldham" class="underline hover:text-navy-900">Oldham</a>,
    <a href="/areas/moorside/" class="underline hover:text-navy-900">Moorside</a>,
    <a href="/areas/lees/" class="underline hover:text-navy-900">Lees</a>,
    <a href="/areas/middleton/" class="underline hover:text-navy-900">Middleton</a> —
    <a href="/areas/" class="underline hover:text-navy-900">see all {site.areas.length} areas</a>.
  </p>
</AreaPageLayout>
