---
import Page from '../../layouts/Page.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { site } from '../../content/site';
import { breadcrumbSchema } from '../../lib/schema';

const area = 'Failsworth';
const slug = area.toLowerCase();
const path = `/areas/${slug}/`;
const url = `${site.url}${path}`;
const schemas = [breadcrumbSchema([
  { name: 'Home', url: `${site.url}/` },
  { name: 'Areas', url: `${site.url}/areas/` },
  { name: area, url },
])];
---
<Page
  title={`Cleaners in Failsworth | From £18/hr | Omni Shine`}
  description={`Reliable domestic, commercial and end-of-tenancy cleaning in Failsworth and Hollinwood from £18/hr. Family-run, eco-friendly, fast quotes.`}
  path={path}
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Areas',href:'/areas/'},{name: area}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl md:text-5xl text-navy-900">Cleaners in {area}</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      We work right across <strong>Failsworth and Hollinwood</strong> — from Oldham Road through Holt Lane and out toward Newton Heath. Failsworth is one of our busiest patches: family homes near the cricket club, terraced rentals along the A62, and a steady stream of end-of-tenancy work for local landlords.
    </p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
    <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
      {site.services.map(s => (
        <li class="flex items-start gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
          <span class="text-slate-500 text-sm">· from £{s.from}</span>
        </li>
      ))}
    </ul>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Failsworth landlords and letting agents</h2>
    <p class="mt-4 text-slate-700">Failsworth has a very active rental market — terraced two-ups along the A62 corridor, modern flats nearer the Metrolink, and a lot of HMO conversions. We handle <a href="/services/end-of-tenancy-cleaning-oldham/" class="underline">end-of-tenancy cleans</a> on tight notice (often turning a property in 24 hours between tenants), with the same fixed-price, inventory-standard checklist and 72-hour re-clean guarantee.</p>

    <h2 class="mt-10 font-display text-2xl text-navy-900">Family homes</h2>
    <p class="mt-4 text-slate-700">For domestic clients we run weekly and fortnightly slots in the Failsworth area on Tuesdays and Thursdays. Most of our recurring clients ask for the same cleaner each visit — we make that work wherever possible.</p>

    <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
    <p class="mt-2 text-slate-700">Chadderton, Hollinwood, Oldham, Moorside, Lees — <a href="/areas/" class="underline hover:text-navy-900">see all areas</a>.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Free quote for {area}</h2>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
