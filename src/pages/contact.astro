---
import { Image } from 'astro:assets';
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { breadcrumbSchema } from '../lib/schema';
import heroHome from '../assets/photos/hero-home.jpg';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Contact', url: `${site.url}/contact/` },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    '@id': `${site.url}/contact/#contact`,
    name: 'Contact Omni Shine Cleaning',
    url: `${site.url}/contact/`,
    about: { '@id': `${site.url}/#business` },
  },
];
---
<Page
  title="Contact Omni Shine | Free Cleaning Quote Oldham"
  description={`Get a free cleaning quote in Oldham within two working hours. Short form on this page, or email ${site.email}. Mon–Fri 5pm–9pm, Sat–Sun 8am–9pm.`}
  path="/contact/"
  schemas={schemas}
>
  <!-- Hero band -->
  <section class="relative isolate overflow-hidden text-white">
    <Image
      src={heroHome}
      alt=""
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      quality={70}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/85 to-navy-700/80"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 md:pb-20">
      <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Contact'}]} />
      <div class="mt-6 max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30">Free quote</p>
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-balance drop-shadow-md">Get in touch</h1>
        <p class="mt-5 text-lg md:text-xl text-slate-100/95 text-balance drop-shadow leading-relaxed">
          Tell us your postcode and what you need — we'll reply within two working hours during opening times. Prefer email? Write to <a class="underline decoration-gold-300 underline-offset-4 hover:text-white" href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Body: form + sidebar -->
  <section class="mx-auto max-w-7xl px-4 py-14 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
        <h2 class="font-display text-2xl text-navy-900">Free quote form</h2>
        <p class="mt-2 text-slate-600">Short. We never share your details, never sell on, never spam.</p>
        <div class="mt-6"><QuoteForm /></div>
      </div>

      <aside class="space-y-5">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-navy-900">Opening hours</h2>
          <dl class="mt-3 space-y-1 text-sm text-slate-700">
            <div class="flex justify-between"><dt>Mon – Fri</dt><dd>5pm – 9pm</dd></div>
            <div class="flex justify-between"><dt>Sat – Sun</dt><dd>8am – 9pm</dd></div>
          </dl>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-navy-900">Email</h2>
          <p class="mt-3"><a href={`mailto:${site.email}`} class="font-medium text-navy-900 underline decoration-gold-400 underline-offset-4">{site.email}</a></p>
          <p class="mt-2 text-slate-600 text-xs">We read every message. Replies go out during opening hours.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-navy-900">Service area</h2>
          <p class="mt-3 text-slate-700 text-sm">{site.areas.length} towns across Oldham, Rochdale and Tameside boroughs.</p>
          <a href="/areas/" class="mt-2 inline-block text-navy-700 font-medium hover:text-navy-900 text-sm">See all areas →</a>
        </div>
        <div class="rounded-2xl border border-gold-400/40 bg-gold-400/10 p-6">
          <h2 class="font-display text-lg text-navy-900">Google Business</h2>
          <a href={site.googleBusinessUrl} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-navy-700 font-medium hover:text-navy-900 text-sm">View Google profile ↗</a>
        </div>
      </aside>
    </div>
  </section>
</Page>
