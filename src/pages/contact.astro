---
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { breadcrumbSchema } from '../lib/schema';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Contact', url: `${site.url}/contact/` },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    '@id': `${site.url}/contact/#contact`,
    name: 'Contact Omni Shine Cleaning',
    url: `${site.url}/contact/`,
    about: { '@id': `${site.url}/#business` },
  },
];
---
<Page
  title="Contact Omni Shine Cleaning | Free Quotes in Oldham"
  description={`Contact Omni Shine Cleaning in Oldham. Free quotes within two working hours. Email ${site.email} or use the short form on this page.`}
  path="/contact/"
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'Contact'}]} />

  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid gap-12 md:grid-cols-[1fr_280px]">
      <div>
        <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">Free quote</span>
        <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900">Get in touch</h1>
        <p class="mt-5 text-lg text-slate-700">
          Tell us your postcode and what you need — we'll reply within two working hours during opening times. Prefer email? Write to <a class="underline hover:text-navy-900" href={`mailto:${site.email}`}>{site.email}</a> directly.
        </p>

        <div class="mt-10 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
          <QuoteForm />
        </div>
      </div>

      <aside class="space-y-6 text-sm">
        <div class="rounded-xl border border-slate-200 p-5">
          <h2 class="font-display text-lg text-navy-900">Opening hours</h2>
          <dl class="mt-3 space-y-1 text-slate-700">
            <div class="flex justify-between"><dt>Mon – Fri</dt><dd>5pm – 9pm</dd></div>
            <div class="flex justify-between"><dt>Sat – Sun</dt><dd>8am – 9pm</dd></div>
          </dl>
        </div>
        <div class="rounded-xl border border-slate-200 p-5">
          <h2 class="font-display text-lg text-navy-900">Email</h2>
          <p class="mt-3">
            <a href={`mailto:${site.email}`} class="font-medium text-navy-900 underline decoration-gold-400 underline-offset-4">{site.email}</a>
          </p>
          <p class="mt-2 text-slate-600 text-xs">We read every message. Replies go out during opening hours.</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-5">
          <h2 class="font-display text-lg text-navy-900">Service area</h2>
          <p class="mt-3 text-slate-700">{site.areas.length} towns around Oldham and Rochdale.</p>
          <a href="/areas/" class="mt-2 inline-block text-navy-700 font-medium hover:text-navy-900">See all areas →</a>
        </div>
        <div class="rounded-xl border border-slate-200 p-5">
          <h2 class="font-display text-lg text-navy-900">Google Business</h2>
          <a href={site.googleBusinessUrl} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-navy-700 font-medium hover:text-navy-900">
            View Google profile ↗
          </a>
        </div>
      </aside>
    </div>
  </section>
</Page>
