---
import { Image } from 'astro:assets';
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { breadcrumbSchema, organizationSchema } from '../lib/schema';
import livingRoom from '../assets/photos/living-room.jpg';
import cleaningSupplies from '../assets/photos/cleaning-supplies.jpg';

const schemas = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'About', url: `${site.url}/about/` },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    '@id': `${site.url}/about/#about`,
    mainEntity: {
      '@type': 'Person',
      name: site.founder,
      jobTitle: 'Founder',
      worksFor: { '@id': `${site.url}/#business` },
    },
  },
];
---
<Page
  title={`About Omni Shine Cleaning | Family-Run Oldham Cleaners | ${site.founder}`}
  description={`Omni Shine is a family-run cleaning service founded in Oldham in ${site.foundingYear} by ${site.founder}. Meet the team and our values.`}
  path="/about/"
  schemas={schemas}
>
  <!-- Hero band -->
  <section class="relative isolate overflow-hidden text-white">
    <Image
      src={livingRoom}
      alt=""
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      quality={70}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/85 to-navy-700/80"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 md:pb-20">
      <Breadcrumbs items={[{name:'Home',href:'/'},{name:'About'}]} />
      <div class="mt-6 max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30">About us</p>
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-balance drop-shadow-md">Meet Omni Shine</h1>
        <p class="mt-5 text-lg md:text-xl text-slate-100/95 text-balance drop-shadow leading-relaxed">A family-run cleaning service founded in Oldham in {site.foundingYear} by {site.founder}.</p>
      </div>
    </div>
  </section>

  <!-- Founder section: 2-col with quote and image -->
  <section class="mx-auto max-w-7xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-2 items-center">
      <div>
        <h2 class="font-display text-3xl text-navy-900">Why we started</h2>
        <p class="mt-5 text-slate-700 leading-relaxed text-lg">
          We started Omni Shine for one simple reason: we think Oldham deserves cleaners who turn up on time, do a genuinely thorough job, and treat clients' homes and businesses with care.
        </p>
        <p class="mt-4 text-slate-700 leading-relaxed">
          {site.founder} grew up here. Knows the towns, the streets, the communities. The business is built around offering something we couldn't always find ourselves — a cleaner you can actually trust, who does what they say they'll do, without over-promising.
        </p>
      </div>
      <figure class="rounded-3xl bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white p-8 md:p-10 shadow-xl">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-gold-400 opacity-70" aria-hidden="true"><path d="M9.583 17.321C8.553 16.227 8 15 8 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C18.553 16.227 18 15 18 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" transform="translate(-2 -1)"/></svg>
        <blockquote class="mt-4 font-display text-xl md:text-2xl leading-relaxed">
          I grew up in Oldham. Starting Omni Shine was about offering something I couldn't always find myself — a cleaner you can actually trust, who does what they say they'll do, without over-promising.
        </blockquote>
        <figcaption class="mt-6 flex items-center gap-3 text-sm text-slate-200">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-gold-400 text-navy-950 font-bold font-display text-lg">SC</span>
          <span>
            <span class="block font-semibold text-white">{site.founder}</span>
            <span class="text-slate-300">Founder, Omni Shine Cleaning</span>
          </span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- Values section -->
  <section class="bg-slate-50 py-16 border-y border-slate-200">
    <div class="mx-auto max-w-7xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Our values</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl text-navy-900">What we stand for</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-display text-xl text-navy-900">Show up</h3>
          <p class="mt-2 text-sm text-slate-700">On time, every time. If we're late, we tell you. If we can't make a slot, we rearrange properly.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-display text-xl text-navy-900">Eco-friendly first</h3>
          <p class="mt-2 text-sm text-slate-700">Plant-based products are our default. Harsher chemicals only when a surface genuinely needs them, never as routine.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-display text-xl text-navy-900">Honest pricing</h3>
          <p class="mt-2 text-sm text-slate-700">Our rates are published. Fixed quotes are fixed. No surprise fees, no inflated materials charges.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-display text-xl text-navy-900">Own our mistakes</h3>
          <p class="mt-2 text-sm text-slate-700">Not right? Tell us within 72 hours and we return to re-clean at no charge. That's the guarantee.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coverage + image -->
  <section class="mx-auto max-w-7xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-2 items-center">
      <Image
        src={cleaningSupplies}
        alt="Eco-friendly cleaning products neatly arranged"
        widths={[400, 600, 800]}
        sizes="(min-width: 768px) 50vw, 100vw"
        quality={80}
        format="webp"
        class="rounded-2xl shadow-xl ring-1 ring-slate-200 object-cover w-full h-[360px] md:h-[440px]"
      />
      <div>
        <h2 class="font-display text-3xl text-navy-900">Where we work</h2>
        <p class="mt-5 text-slate-700 leading-relaxed text-lg">We cover <strong>{site.areas.length} towns</strong> across Oldham, Rochdale and Tameside.</p>
        <p class="mt-4 text-slate-700 leading-relaxed">{site.areas.slice(0, -1).join(', ')} and {site.areas.at(-1)}.</p>
        <a href="/areas/" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-navy-900 px-5 py-3 font-medium text-white hover:bg-navy-700 transition">
          See all areas
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Honesty about being new -->
  <section class="mx-auto max-w-7xl px-4 pb-16">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 md:p-12 max-w-4xl mx-auto">
      <h2 class="font-display text-2xl text-navy-900">Being honest about being new</h2>
      <p class="mt-4 text-slate-700 leading-relaxed">Omni Shine was founded in {site.foundingYear}. That means a few things. It means we have limited reviews so far — but every new client gets our full attention. It also means we are still finalising certain accreditations (insurance paperwork, DBS checks, ICO registration) that older companies take for granted. Ask us about our current position at any point — we will tell you the truth, in writing, before you book.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white py-20">
    <div class="relative mx-auto max-w-5xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl">Get in touch with Sangita</h2>
        <p class="mt-4 text-slate-200">Questions, quotes, or just to say hello.</p>
      </div>
      <div class="mt-10 rounded-3xl bg-white text-slate-900 p-6 md:p-10 shadow-2xl">
        <QuoteForm />
      </div>
    </div>
  </section>
</Page>
