---
import { Image } from 'astro:assets';
import Page from '../layouts/Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { breadcrumbSchema, organizationSchema } from '../lib/schema';
import livingRoom from '../assets/photos/living-room.jpg';

const schemas = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'About', url: `${site.url}/about/` },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    '@id': `${site.url}/about/#about`,
    mainEntity: {
      '@type': 'Person',
      name: site.founder,
      jobTitle: 'Founder',
      worksFor: { '@id': `${site.url}/#business` },
    },
  },
];
---
<Page
  title={`About Omni Shine Cleaning | Family-Run Oldham Cleaners | ${site.founder}`}
  description={`Omni Shine is a family-run cleaning service founded in Oldham in ${site.foundingYear} by ${site.founder}. Meet the team and our values.`}
  path="/about/"
  schemas={schemas}
>
  <Breadcrumbs items={[{name:'Home',href:'/'},{name:'About'}]} />

  <section class="mx-auto max-w-3xl px-4 py-12">
    <span class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-navy-900">About us</span>
    <h1 class="mt-4 font-display text-4xl md:text-5xl text-navy-900">Meet Omni Shine</h1>
    <p class="mt-5 text-lg text-slate-700 leading-relaxed">
      Omni Shine Cleaning is a family-run cleaning service founded in <strong>Oldham in {site.foundingYear}</strong> by <strong>{site.founder}</strong>. We started the business for one simple reason: we think Oldham deserves cleaners who turn up on time, do a genuinely thorough job, and treat clients' homes and businesses with care.
    </p>

    <figure class="mt-10 rounded-3xl bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white p-8 md:p-12">
      <blockquote class="font-display text-xl md:text-2xl leading-relaxed">
        &ldquo;I grew up in Oldham. I know the towns, the streets, the communities. Starting Omni Shine was about offering something I couldn't always find myself — a cleaner you can actually trust, who does what they say they'll do, without over-promising.&rdquo;
      </blockquote>
      <figcaption class="mt-6 flex items-center gap-3 text-sm text-slate-200">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gold-400 text-navy-950 font-bold font-display">SC</span>
        <span>
          <span class="block font-semibold text-white">{site.founder}</span>
          <span class="text-slate-300">Founder, Omni Shine Cleaning</span>
        </span>
      </figcaption>
    </figure>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Our values</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-slate-200 p-5">
        <h3 class="font-semibold text-navy-900">Show up</h3>
        <p class="mt-2 text-sm text-slate-700">On time, every time. If we're late, we tell you. If we can't make a slot, we rearrange properly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-5">
        <h3 class="font-semibold text-navy-900">Eco-friendly first</h3>
        <p class="mt-2 text-sm text-slate-700">Plant-based products are our default. Harsher chemicals only when a surface genuinely needs them, never as routine.</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-5">
        <h3 class="font-semibold text-navy-900">Honest pricing</h3>
        <p class="mt-2 text-sm text-slate-700">Our rates are published. Fixed quotes are fixed. No surprise fees, no inflated materials charges.</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-5">
        <h3 class="font-semibold text-navy-900">Own our mistakes</h3>
        <p class="mt-2 text-sm text-slate-700">Not right? Tell us within 72 hours and we return to re-clean at no charge. That's the guarantee.</p>
      </div>
    </div>

    <h2 class="mt-14 font-display text-2xl text-navy-900">Where we work</h2>
    <p class="mt-4 text-slate-700">We cover <strong>{site.areas.length} towns</strong> around Oldham, Rochdale and Tameside: {site.areas.slice(0, -1).join(', ')} and {site.areas.at(-1)}. See <a href="/areas/" class="underline hover:text-navy-900">all areas</a>.</p>

    <Image
      src={livingRoom}
      alt="Bright, freshly cleaned living room with natural light"
      widths={[600, 900, 1200]}
      sizes="(min-width: 768px) 768px, 100vw"
      quality={78}
      format="webp"
      class="mt-10 rounded-2xl shadow-xl ring-1 ring-slate-200 w-full h-auto object-cover"
    />

    <h2 class="mt-14 font-display text-2xl text-navy-900">Being honest about being new</h2>
    <p class="mt-4 text-slate-700">Omni Shine was founded in {site.foundingYear}. That means a few things. It means we have limited reviews so far — but every new client gets our full attention. It also means we are still finalising certain accreditations (insurance paperwork, DBS checks, ICO registration) that older companies take for granted. Ask us about our current position at any point — we will tell you the truth, in writing, before you book.</p>

    <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-sm">
      <h2 class="font-display text-2xl text-navy-900">Get in touch</h2>
      <p class="mt-2 text-slate-600">Questions, quotes, or just to say hello.</p>
      <div class="mt-6"><QuoteForm /></div>
    </div>
  </section>
</Page>
