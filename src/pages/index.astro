---
import Page from '../layouts/Page.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AreaCard from '../components/AreaCard.astro';
import ReviewCard from '../components/ReviewCard.astro';
import FaqList from '../components/FaqList.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';
import { approvedReviews } from '../content/reviews';
import { faqs } from '../content/faq';
import {
  localBusinessSchema,
  organizationSchema,
  websiteSchema,
  faqSchema,
} from '../lib/schema';

const topFaqs = faqs.slice(0, 6);
const reviews = approvedReviews();

const schemas = [
  localBusinessSchema(),
  organizationSchema(),
  websiteSchema(),
  faqSchema(topFaqs),
];

const why = [
  {
    title: 'Family-run, local',
    body: `Founded in Oldham in ${site.foundingYear} by ${site.founder}. You deal with the owner directly — no call-centre, no middle-man.`,
    icon: 'users',
  },
  {
    title: 'Eco-friendly by default',
    body: 'Plant-based products that actually work. Fragrance-free alternatives on request for allergy-sensitive households.',
    icon: 'leaf',
  },
  {
    title: 'Weekends included',
    body: 'Saturday and Sunday 8am–9pm — no weekend surcharges, and weekday slots from 5pm for working households.',
    icon: 'calendar',
  },
  {
    title: 'Honest pricing',
    body: 'Our rates are published on the pricing page. Fixed quotes for one-off work. No surprise fees, ever.',
    icon: 'tag',
  },
];

const whyIcons: Record<string, string> = {
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 4 13 7 7 0 0 1 19 4c0 4-3 11-8 16Z"/><path d="M13 22V13"/>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
  tag: '<path d="M20.59 13.41 13 21a2 2 0 0 1-2.83 0L2 12.83V3h9.83Z"/><line x1="7" y1="7" x2="7.01" y2="7"/>',
};
---
<Page
  title="Professional Cleaning Services in Oldham | Omni Shine Cleaning"
  description="Family-run cleaners in Oldham. Domestic from £18/hr, end-of-tenancy from £180, commercial from £22/hr. Eco-friendly, weekends included, free quotes."
  path="/"
  schemas={schemas}
>
  <Hero />
  <TrustStrip />

  <!-- Services -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Our Services</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl text-navy-900">Cleaning services in Oldham, done properly</h2>
      <p class="mt-4 text-slate-600">Pick the service you need — or tell us what you're dealing with and we'll build the right plan.</p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {site.services.map(s => (
        <ServiceCard
          href={`/services/${s.slug}/`}
          name={s.name}
          blurb={s.blurb}
          from={s.from}
          unit={s.unit}
          icon={s.icon}
        />
      ))}
    </div>
  </section>

  <!-- Areas -->
  <section class="bg-slate-50 py-20 border-y border-slate-200">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Coverage</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl text-navy-900">{site.areas.length} towns across Oldham &amp; Rochdale</h2>
        <p class="mt-4 text-slate-600">Click your area for local detail — or skip ahead and get a quote.</p>
      </div>

      <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {site.areas.map(a => (
          <AreaCard
            href={`/areas/${a.toLowerCase()}/`}
            name={a}
            hasPage={(site.areaPages as readonly string[]).includes(a)}
          />
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/areas/" class="inline-flex items-center gap-2 text-navy-700 font-semibold hover:text-navy-900">
          See all area pages
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Why Omni Shine</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl text-navy-900">What makes us different</h2>
      <p class="mt-4 text-slate-600">We're new, but we're local, and we care about doing the basics brilliantly.</p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {why.map(w => (
        <div class="relative">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-navy-900 text-gold-400">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={whyIcons[w.icon]}></svg>
          </span>
          <h3 class="mt-5 font-display text-xl text-navy-900">{w.title}</h3>
          <p class="mt-2 text-slate-600 text-[15px]">{w.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="bg-navy-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-20 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gold-400 blur-3xl rounded-full -translate-y-1/2 translate-x-1/2"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-20">
      <div class="grid gap-10 md:grid-cols-[1fr_auto] items-end">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-gold-400">Transparent pricing</p>
          <h2 class="mt-3 font-display text-3xl md:text-4xl">Real prices, not "request a quote for a quote"</h2>
          <p class="mt-4 text-slate-200 max-w-xl">Most cleaners hide their rates. We don't. Here's exactly what you'll pay — and what's included.</p>
          <dl class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-6">
            {site.services.slice(0, 3).map(s => (
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-400">{s.short}</dt>
                <dd class="mt-1 text-2xl font-display font-semibold text-white">
                  £{s.from}<span class="text-sm text-slate-300 ml-1">{s.unit}</span>
                </dd>
              </div>
            ))}
          </dl>
        </div>
        <a href="/pricing/" class="inline-flex items-center gap-2 rounded-lg bg-gold-400 px-6 py-3.5 text-base font-semibold text-navy-950 hover:bg-gold-500 transition">
          See full pricing
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews (only if approved ones exist) -->
  {reviews.length > 0 && (
    <section class="bg-slate-50 py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="text-center max-w-2xl mx-auto">
          <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Clients</p>
          <h2 class="mt-3 font-display text-3xl md:text-4xl text-navy-900">What our clients say</h2>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {reviews.map(r => (
            <ReviewCard
              author={r.author}
              company={r.company}
              body={r.body}
              rating={r.rating}
              date={r.date}
              location={r.location}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Questions</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl text-navy-900">Answers we give most days</h2>
    </div>
    <div class="mt-12">
      <FaqList items={topFaqs} />
    </div>
    <div class="mt-10 text-center">
      <a href="/faq/" class="inline-flex items-center gap-2 text-navy-700 font-semibold hover:text-navy-900">
        See all FAQs
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA / form -->
  <section id="quote" class="relative overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white py-24">
    <div class="absolute inset-0 opacity-25 pointer-events-none" aria-hidden="true">
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gold-400 blur-3xl rounded-full translate-y-1/2 -translate-x-1/3"></div>
    </div>
    <div class="relative mx-auto max-w-5xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold-400">Free quote</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl">Tell us what you need</h2>
        <p class="mt-4 text-slate-200">Short form. No spam. We reply within two working hours during opening times.</p>
      </div>
      <div class="mt-12 rounded-3xl bg-white text-slate-900 p-6 md:p-10 shadow-2xl">
        <QuoteForm />
      </div>
    </div>
  </section>
</Page>
