---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Page from './Page.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { site } from '../content/site';

interface Props {
  area: string;
  slug?: string;
  title: string;
  description: string;
  schemas?: object[];
  image: ImageMetadata;
  imageAlt: string;
  intro: string;
  /** "Saddleworth" / "Tameside" / "Oldham" — shown as small label */
  borough?: string;
}

const {
  area,
  slug = Astro.props.slug ?? area.toLowerCase(),
  title,
  description,
  schemas,
  image,
  imageAlt,
  intro,
  borough,
} = Astro.props;

const path = `/areas/${slug}/`;
---
<Page title={title} description={description} path={path} schemas={schemas}>
  <!-- Full-bleed hero with photo -->
  <section class="relative isolate overflow-hidden text-white">
    <Image
      src={image}
      alt={imageAlt}
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      quality={75}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/80 to-navy-700/70"></div>

    <div class="relative mx-auto max-w-7xl px-4 pt-6 pb-16 md:pb-24">
      <Breadcrumbs items={[
        { name: 'Home', href: '/' },
        { name: 'Areas', href: '/areas/' },
        { name: area },
      ]} />
      <div class="mt-8 max-w-3xl">
        {borough && (
          <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30 backdrop-blur">{borough}</p>
        )}
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-balance drop-shadow-md">
          Cleaners in {area}
        </h1>
        <p class="mt-5 text-lg md:text-xl text-slate-100/95 text-balance drop-shadow leading-relaxed">{intro}</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#quote" class="inline-flex items-center gap-2 rounded-lg bg-gold-400 px-6 py-3 text-base font-semibold text-navy-950 shadow-lg hover:bg-gold-500 transition">
            Get a free {area} quote
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/pricing/" class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/5 px-5 py-3 text-sm font-medium text-white/95 hover:bg-white/10 transition backdrop-blur">
            See pricing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2-column body -->
  <section class="mx-auto max-w-7xl px-4 py-14 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_320px]">
      <article class="prose-area max-w-none">
        <slot />

        <h2 class="mt-12 font-display text-2xl text-navy-900">Services available in {area}</h2>
        <ul class="mt-4 grid gap-2 text-slate-700 md:grid-cols-2">
          {site.services.map(s => (
            <li class="flex items-start gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              <a href={`/services/${s.slug}/`} class="underline decoration-slate-200 underline-offset-4 hover:text-navy-900 hover:decoration-navy-700">{s.name}</a>
              <span class="text-slate-500 text-sm">· from £{s.from}</span>
            </li>
          ))}
        </ul>

        <slot name="after-services" />

        <h2 class="mt-12 font-display text-2xl text-navy-900">Nearby areas we also cover</h2>
        <slot name="nearby">
          <p class="mt-2 text-slate-700">
            <a href="/areas/" class="underline hover:text-navy-900">See all {site.areas.length} areas</a>.
          </p>
        </slot>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-5 lg:sticky lg:top-24 self-start">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-navy-900">Quick prices</h2>
          <dl class="mt-4 space-y-2.5 text-sm text-slate-700">
            {site.services.map(s => (
              <div class="flex items-center justify-between gap-3">
                <dt class="text-slate-600">{s.short}</dt>
                <dd class="font-semibold text-navy-900">£{s.from}<span class="text-xs font-normal text-slate-500 ml-1">{s.unit}</span></dd>
              </div>
            ))}
          </dl>
          <a href="/pricing/" class="mt-4 inline-flex items-center gap-1 text-sm text-navy-700 font-medium hover:text-navy-900">
            Full pricing →
          </a>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-lg text-navy-900">Opening hours</h2>
          <dl class="mt-3 space-y-1 text-sm text-slate-700">
            <div class="flex justify-between"><dt>Mon – Fri</dt><dd>5pm – 9pm</dd></div>
            <div class="flex justify-between"><dt>Sat – Sun</dt><dd>8am – 9pm</dd></div>
          </dl>
          <p class="mt-4 text-xs text-slate-500">We reply within 2 working hours during opening times.</p>
        </div>

        <div class="rounded-2xl border border-gold-400/40 bg-gold-400/10 p-6">
          <h2 class="font-display text-lg text-navy-900">Trust badges</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate-800">
            <li class="flex gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>Family-run, founded 2026</li>
            <li class="flex gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>Eco-friendly products</li>
            <li class="flex gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>Same cleaner each visit</li>
            <li class="flex gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>72-hr re-clean guarantee</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- Full-width quote form section -->
  <section id="quote" class="relative isolate overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 text-white py-20">
    <div class="absolute inset-0 opacity-25 pointer-events-none" aria-hidden="true">
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gold-400 blur-3xl rounded-full translate-y-1/2 -translate-x-1/3"></div>
    </div>
    <div class="relative mx-auto max-w-5xl px-4">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold-400">Free quote</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl">Get a free quote for {area}</h2>
        <p class="mt-4 text-slate-200">Postcode, service, message — that's all we need. No spam.</p>
      </div>
      <div class="mt-10 rounded-3xl bg-white text-slate-900 p-6 md:p-10 shadow-2xl">
        <QuoteForm />
      </div>
    </div>
  </section>
</Page>
