---
const items = [
  { label: '14 towns covered around Oldham' },
  { label: 'Eco-friendly products included' },
  { label: 'Same cleaner each visit' },
  { label: 'Weekend availability, no surcharge' },
];
---
<section class="border-y border-slate-200 bg-slate-50">
  <ul class="mx-auto max-w-6xl px-4 py-4 grid grid-cols-2 md:grid-cols-4 gap-y-3 gap-x-6 text-sm text-slate-600">
    {items.map(i => (
      <li class="flex items-start gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-500 shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="font-medium">{i.label}</span>
      </li>
    ))}
  </ul>
</section>
