---
import { site } from '../content/site';

interface Props {
  /** Slug of the service this page is for — excluded from the grid. Use "domestic-cleaning-oldham" etc. */
  currentSlug?: string;
  /** Optional heading override */
  heading?: string;
  /** Optional subhead */
  sub?: string;
  /** Show service-x-area combo links beneath the main grid */
  showCombos?: boolean;
}

const { currentSlug, heading = 'Other cleaning services we offer', sub, showCombos = true } = Astro.props;

// Match by service-name root rather than full slug, so /services/domestic-cleaning-royton/ also excludes domestic-cleaning-oldham
function rootOf(slug: string): string {
  // strip the trailing -<area> if any. Service names are 1-3 words ending in -oldham/-rochdale/-saddleworth/-middleton/-royton/-ashton-under-lyne
  return slug
    .replace(/-(oldham|rochdale|saddleworth|middleton|royton|ashton-under-lyne)$/i, '');
}
const currentRoot = currentSlug ? rootOf(currentSlug) : null;

const others = site.services.filter(s => rootOf(s.slug) !== currentRoot);

// Combo pages excluding any that match the current root
const combos = site.serviceAreaCombos.filter(c => {
  if (!currentRoot) return true;
  return rootOf(c.slug) !== currentRoot;
}).slice(0, 4);

const icons: Record<string, string> = {
  home: '<path d="M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1V9.5Z"/>',
  briefcase: '<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 13h18"/>',
  sparkles: '<path d="M12 3v4m0 10v4M3 12h4m10 0h4M5.6 5.6l2.8 2.8m7.2 7.2 2.8 2.8M5.6 18.4l2.8-2.8m7.2-7.2 2.8-2.8"/>',
  key: '<circle cx="7.5" cy="15.5" r="4.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/>',
  'hard-hat': '<path d="M2 18h20"/><path d="M10 2h4v6h-4z"/><path d="M4 15a8 8 0 0 1 16 0"/>',
};
---
<section class="mt-16">
  <div class="border-t border-slate-200 pt-12">
    <p class="text-xs font-semibold tracking-widest uppercase text-gold-600">Explore</p>
    <h2 class="mt-2 font-display text-2xl md:text-3xl text-navy-900">{heading}</h2>
    {sub && <p class="mt-2 text-slate-600">{sub}</p>}

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {others.map(s => (
        <a href={`/services/${s.slug}/`} class="group block rounded-2xl border border-slate-200 bg-white p-5 hover:border-gold-400 hover:shadow-md hover:-translate-y-0.5 transition">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-navy-900 text-gold-400">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[s.icon] || icons.sparkles}></svg>
          </span>
          <h3 class="mt-4 font-display text-lg text-navy-900 group-hover:text-navy-700">{s.name}</h3>
          <p class="mt-1.5 text-sm text-slate-600 leading-snug">{s.blurb}</p>
          <p class="mt-4 text-sm font-semibold text-navy-700">From £{s.from} <span class="font-normal text-slate-500">{s.unit}</span> →</p>
        </a>
      ))}
    </div>

    {showCombos && combos.length > 0 && (
      <div class="mt-10 rounded-2xl bg-slate-50 border border-slate-200 p-6">
        <h3 class="font-semibold text-navy-900">Looking for an area-specific service page?</h3>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2 text-sm">
          {combos.map(c => (
            <li>
              <a href={`/services/${c.slug}/`} class="text-navy-700 hover:text-navy-900 hover:underline inline-flex items-center gap-1">
                ✦ {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>
