---
import { Image } from 'astro:assets';
import heroBg from '../assets/photos/hero-home.jpg';
import { site } from '../content/site';

interface Props {
  headline?: string;
  sub?: string;
  chips?: readonly string[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  headline = site.heroHeadline,
  sub = site.heroSub,
  chips = site.trustChips,
  ctaLabel = 'Get a Free Quote',
  ctaHref = '/contact/',
} = Astro.props;
---
<section class="relative isolate overflow-hidden text-white">
  <!-- Background image -->
  <Image
    src={heroBg}
    alt=""
    widths={[640, 960, 1280, 1920, 2400]}
    sizes="100vw"
    quality={75}
    format="webp"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <!-- Gradient overlay -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/85 to-navy-700/80"></div>
  <!-- Decorative blobs -->
  <div class="absolute inset-0 -z-10 opacity-40 mix-blend-screen pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-navy-500 blur-3xl"></div>
    <div class="absolute top-1/3 -right-32 w-[28rem] h-[28rem] rounded-full bg-gold-400/60 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 py-20 md:py-32 text-center">
    <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-xs font-medium tracking-wide uppercase text-white/90 ring-1 ring-white/20 backdrop-blur">
      <span class="h-1.5 w-1.5 rounded-full bg-gold-400 animate-pulse"></span>
      Now taking bookings in Oldham
    </p>
    <h1 class="mt-6 font-display text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight text-balance drop-shadow-md">
      {headline}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-slate-100/95 text-balance drop-shadow">
      {sub}
    </p>

    <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href={ctaHref} class="inline-flex items-center gap-2 rounded-lg bg-gold-400 px-7 py-3.5 text-base font-semibold text-navy-950 shadow-xl shadow-gold-400/20 hover:bg-gold-500 transition">
        {ctaLabel}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/pricing/" class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/5 px-5 py-3 text-sm font-medium text-white/95 hover:bg-white/10 transition backdrop-blur">
        See transparent pricing
      </a>
    </div>

    <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-sm text-slate-200/95">
      {chips.map(c => (
        <li class="inline-flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-gold-400" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          {c}
        </li>
      ))}
    </ul>
  </div>
</section>
