---
interface Props {
  author: string;
  company?: string;
  body: string;
  rating: number;
  date: string;
  location?: string;
}
const { author, company, body, rating, date, location } = Astro.props;
const dateFmt = new Date(date).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
---
<figure class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex items-center gap-1 text-gold-500" aria-label={`Rated ${rating} out of 5`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg width="18" height="18" viewBox="0 0 24 24" fill={i < rating ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15 9 22 9.3 16.5 14 18 21 12 17.3 6 21 7.5 14 2 9.3 9 9"/></svg>
    ))}
  </div>
  <blockquote class="mt-4 text-slate-700 text-[15px] leading-relaxed">&ldquo;{body}&rdquo;</blockquote>
  <figcaption class="mt-5 text-sm text-slate-600 border-t border-slate-100 pt-4">
    <span class="font-semibold text-navy-900">{author}</span>
    {company && author !== company && <span class="text-slate-500"> · {company}</span>}
    <time datetime={date} class="block text-xs text-slate-500 mt-0.5">
      {location ? `${location} · ` : ''}{dateFmt}
    </time>
  </figcaption>
</figure>
