---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  badge?: string;
  headline: string;
  sub?: string;
  height?: 'tall' | 'standard' | 'short';
}

const { image, alt, badge, headline, sub, height = 'standard' } = Astro.props;

const heightClass = {
  tall: 'py-24 md:py-32',
  standard: 'py-16 md:py-24',
  short: 'py-12 md:py-16',
}[height];
---
<section class="relative isolate overflow-hidden text-white">
  <Image
    src={image}
    alt={alt}
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    quality={75}
    format="webp"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-navy-950/95 via-navy-900/80 to-navy-700/75"></div>

  <div class:list={['relative mx-auto max-w-3xl px-4 text-center', heightClass]}>
    {badge && (
      <p class="inline-flex items-center rounded-full bg-gold-400/20 px-3 py-1 text-xs font-semibold text-gold-200 ring-1 ring-gold-400/30 backdrop-blur">{badge}</p>
    )}
    <h1 class="mt-4 font-display text-4xl md:text-5xl font-semibold tracking-tight text-balance drop-shadow-md">{headline}</h1>
    {sub && <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-100/95 text-balance drop-shadow">{sub}</p>}
  </div>
</section>
