---
interface Props {
  href: string;
  name: string;
  blurb: string;
  from: number;
  unit: string;
  icon: string;
}
const { href, name, blurb, from, unit, icon } = Astro.props;

const icons: Record<string, string> = {
  home: '<path d="M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1V9.5Z"/>',
  briefcase: '<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 13h18"/>',
  sparkles: '<path d="M12 3v4m0 10v4M3 12h4m10 0h4M5.6 5.6l2.8 2.8m7.2 7.2 2.8 2.8M5.6 18.4l2.8-2.8m7.2-7.2 2.8-2.8"/>',
  key: '<circle cx="7.5" cy="15.5" r="4.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/>',
  'hard-hat': '<path d="M2 18h20"/><path d="M10 2h4v6h-4z"/><path d="M4 15a8 8 0 0 1 16 0"/>',
};
---
<a
  href={href}
  class="group relative block rounded-2xl border border-slate-200 bg-white p-6 hover:border-gold-400 hover:shadow-lg hover:-translate-y-0.5 transition"
>
  <div class="flex items-center justify-between">
    <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-navy-900 text-gold-400">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[icon] || icons.sparkles}></svg>
    </span>
    <span class="rounded-full bg-gold-400/20 px-2.5 py-1 text-xs font-semibold text-navy-900">From £{from}</span>
  </div>
  <h3 class="mt-5 font-display text-xl text-navy-900">{name}</h3>
  <p class="mt-2 text-sm text-slate-600">{blurb}</p>
  <p class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-navy-700 group-hover:text-navy-900">
    Learn more
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="transition group-hover:translate-x-0.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
  </p>
</a>
