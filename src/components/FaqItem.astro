---
interface Props { q: string; a: string; open?: boolean; }
const { q, a, open = false } = Astro.props;
---
<details class="group border-b border-slate-200 py-5" {open ? 'open' : ''}>
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy-900 text-[17px]">
    <span>{q}</span>
    <span aria-hidden="true" class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-slate-300 text-slate-500 transition group-open:rotate-45 group-open:border-navy-900 group-open:text-navy-900">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </span>
  </summary>
  <div class="mt-3 text-slate-700 leading-relaxed">{a}</div>
</details>
